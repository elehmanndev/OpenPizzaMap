node_modules
.env
.env.local
.env.*

# Security audits and session notes contain operational details
# (infra paths, past incident specifics, internal architecture, sometimes
# secrets-in-prose). Kept in the Obsidian vault only — see
# Projects/3_Openpizzamap/sessions in the vault for the mirror.
AUDIT-*.md
notes/sessions/

# Database dumps / backups — never commit production data.
*.sql.gz
*.sql.zip
*.dump
*.bak
backup*.sql

# SQLite dev database. Schema is MySQL on prod; dev.db was a leftover
# from an earlier provider. Keep it ignored so it can't be re-committed.
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
.prisma
*.log
.claude/
.playwright-mcp/

scripts/lib/.tripadvisor-budget.json

# Per-host deploy state. Sentinels + asset-version manifest are written by
# scripts on each Hostinger boot/deploy and must not be checked in.
.builds/

# User-uploaded content. On Hostinger this path is a symlink to
# ~/domains/openpizzamap.com/persistent/uploads/ so runtime-created
# subdirectories survive git deploys (set up 2026-05-23). The legacy
# flat photos under public/uploads/places/*.jpg remain tracked for
# history; do not commit NEW binaries here.
public/uploads/

# Script artifacts. Everything under data/ is regenerable: scrape outputs,
# external-API caches, audit/dedup/error reports. The dirs themselves are
# created on demand by scripts/lib/bootstrap.js.
data/

# Legacy: catch-all for anything still landing at the repo root from older
# scripts that haven't moved over yet. Anchored with a leading `/` so they
# apply only to repo root, not equivalently-named files under src/ etc.
/*-scrape.json
/*-cache.json
/dedup-*.json
/*-report.json
/*-audit.json
/*-debug.html
/scrape-result.json
/tasteatlas-*.json
/import-errors.json
/import-log*.txt

# Screenshots and reference images dropped at the repo root. Keeps
# public/uploads/places/*.png (committed deliberately) untouched.
/*.png
