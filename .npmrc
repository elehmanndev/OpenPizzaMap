# Slim down npm install on Hostinger auto-deploys. Each setting trims
# either network calls (which spawn fetch subprocesses) or extra walks
# of node_modules that pile up under the shared host's 120-process cap.
#
# prefer-offline   - hit the local cache before going to the registry.
#                    Warm installs become near-no-op fetch-wise.
# audit=false      - skip the `npm audit` network call on every install.
# fund=false       - skip the funding-message walk of every package.
# progress=false   - kill the spinner TTY thread; pure log lines are
#                    enough for the deploy log.
# update-notifier=false - one less background fetch.
prefer-offline=true
audit=false
fund=false
progress=false
update-notifier=false
