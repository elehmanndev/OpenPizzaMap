{
  "name": "openpizzamap",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node src/app.js",
    "test": "node --test",
    "start": "/opt/alt/alt-nodejs20/root/bin/node scripts/deploy/migrate.js && /opt/alt/alt-nodejs20/root/bin/node src/app.js",
    "start:local": "node scripts/deploy/migrate.js && node src/app.js",
    "build": "npm run prisma:generate && npm run build:asset-version",
    "build:asset-version": "node scripts/deploy/build-asset-version.js",
    "postinstall": "node scripts/deploy/chmod-prisma-engines.js && npm run prisma:generate && node scripts/deploy/chmod-prisma-engines.js && node scripts/deploy/setup-playwright.js && npm run build:asset-version && node scripts/deploy/touch-passenger-restart.js",
    "seed": "npm run prisma:seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "users:backfill": "node scripts/backfills/backfill-usernames.js",
    "admin:password": "node scripts/admin/set-admin-password.js",
    "sitemap:build": "node scripts/deploy/build-sitemap.js",
    "landing:recompute": "node scripts/backfills/recompute-landing.js",
    "thumbs:build": "node scripts/deploy/build-thumbs.js"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@quixo3/prisma-session-store": "^3.1.13",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "resend": "^3.2.0",
    "sanitize-html": "^2.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "prisma": "^5.18.0",
    "sharp": "^0.34.5"
  }
}
