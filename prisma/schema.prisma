generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String?
  displayName  String
  username     String?      @unique @db.VarChar(20)
  role         UserRole     @default(user)
  emailVerifiedAt DateTime?
  verificationTokenHash String?
  verificationTokenExpiresAt DateTime?
  newsletterOptIn Boolean @default(true)
  resetTokenHash String?
  resetTokenExpiresAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  googleId     String?      @unique
  reviews      Submission[] @relation("ReviewedBy")
  submissions  Submission[] @relation("UserSubmissions")
}

model Place {
  id            Int         @id @default(autoincrement())
  name          String
  addressLine   String
  city          String
  region        String?
  postalCode    String?
  country       String
  lat           Decimal     @db.Decimal(10, 7)
  lng           Decimal     @db.Decimal(10, 7)
  priceLevel    Int
  stylesJson    String
  dineIn        Boolean     @default(true)
  takeaway      Boolean     @default(true)
  delivery      Boolean     @default(false)
  websiteUrl    String?
  googleMapsUrl String?
  instagramUrl  String?
  status        PlaceStatus @default(active)
  slug          String?     @unique
  cityId        Int?
  cityRef       City?       @relation(fields: [cityId], references: [id])
  faqs          Faq[]
  descriptionHtml String?   @db.LongText
  heroImageUrl  String?
  seoTitle      String?
  seoDescription String?    @db.VarChar(200)
  isVisible     Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([city])
  @@index([lat])
  @@index([lng])
}

model Country {
  code          String   @id @db.Char(2)
  name          String?
  slug          String?  @unique
  introHtml     String?  @db.LongText
  heroImageUrl  String?
  seoTitle      String?
  seoDescription String? @db.VarChar(200)
  isVisible     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isVisible])
}

model City {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String
  countryCode   String   @db.Char(2)
  introHtml     String?  @db.LongText
  heroImageUrl  String?
  seoTitle      String?
  seoDescription String? @db.VarChar(200)
  isVisible     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  places        Place[]
  faqs          Faq[]

  @@unique([countryCode, slug])
  @@index([countryCode])
  @@index([isVisible])
}

enum FaqScope {
  global
  country
  city
  place
}

model Faq {
  id           Int      @id @default(autoincrement())
  scope        FaqScope
  countryCode  String?  @db.Char(2)
  cityId       Int?
  placeId      Int?
  question     String   @db.VarChar(200)
  answerHtml   String   @db.LongText
  sortOrder    Int      @default(0)
  isVisible    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  city         City?    @relation(fields: [cityId], references: [id])
  place        Place?   @relation(fields: [placeId], references: [id])

  @@index([scope])
  @@index([countryCode])
  @@index([cityId])
  @@index([placeId])
  @@index([isVisible])
}

model Page {
  id            Int      @id @default(autoincrement())
  key           String   @unique @db.VarChar(60)
  title         String   @db.VarChar(120)
  bodyHtml      String   @db.LongText
  seoTitle      String?
  seoDescription String? @db.VarChar(200)
  isVisible     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isVisible])
}

model Submission {
  id               Int              @id @default(autoincrement())
  userId           Int
  type             SubmissionType
  targetPlaceId    Int?
  payloadJson      String
  status           SubmissionStatus @default(pending)
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  reviewedAt       DateTime?
  reviewedByUserId Int?
  reviewedBy       User?            @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])
  user             User             @relation("UserSubmissions", fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([reviewedByUserId], map: "Submission_reviewedByUserId_fkey")
  @@index([userId], map: "Submission_userId_fkey")
}

enum UserRole {
  user
  admin
}

enum PlaceStatus {
  active
  closed
  temp_closed
}

enum SubmissionType {
  new_place
  edit_place
}

enum SubmissionStatus {
  pending
  approved
  rejected
}
