generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String?
  displayName  String
  username     String?      @unique @db.VarChar(20)
  role         UserRole     @default(user)
  emailVerifiedAt DateTime?
  verificationTokenHash String?
  verificationTokenExpiresAt DateTime?
  newsletterOptIn Boolean @default(true)
  resetTokenHash String?
  resetTokenExpiresAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  googleId     String?      @unique
  avatarUrl    String?      @db.Text
  reviews      Submission[] @relation("ReviewedBy")
  submissions  Submission[] @relation("UserSubmissions")
  visits       Visit[]
  favorites    Favorite[]
  placeReviews Review[]
}

model Place {
  id            Int         @id @default(autoincrement())
  name          String
  addressLine   String
  city          String
  region        String?     // Province / Comunidad — populated by enricher
                            // from Google Places administrative_area_level_2.
                            // Used by the city-hub metro view (Tier 2:
                            // "near {city}") to match places in the same
                            // admin region as the landing-city.
  postalCode    String?
  country       String
  lat           Decimal     @db.Decimal(10, 7)
  lng           Decimal     @db.Decimal(10, 7)
  priceLevel    Int
  stylesJson    String
  dineIn        Boolean     @default(true)
  takeaway      Boolean     @default(true)
  delivery      Boolean     @default(false)
  reservations  Boolean     @default(false)
  outdoorSeating Boolean    @default(false)
  phone         String?
  websiteUrl    String?
  googleMapsUrl String?
  instagramUrl  String?
  facebookUrl   String?
  openingHours  String?     @db.Text       // schema.org weekly format ("Mo-Sa 12:00-23:00") or JSON if structured
  enrichedAt    DateTime?                  // last successful enrichment pass — used to skip recently-touched rows
  enrichPriorityAt DateTime?               // set when an admin edits the place; opm-runner queues order by this DESC so edited spots jump to the front
  osmCheckedAt  DateTime?                  // last OpenStreetMap lookup (success OR miss); rotates the OSM queue so rows with no OSM match don't re-check forever
  // TripAdvisor Content API enrichment (additive — only set when scrape-venue
  // ran with --with-tripadvisor or the TA enricher phase ran). Cached up to
  // 30 days per TA's licensing terms; reviews are explicitly NOT stored.
  tripadvisorLocationId   Int?
  tripadvisorRanking      String?          // e.g. "#95 of 516 Places to Eat in Sabadell"
  tripadvisorRating       Decimal? @db.Decimal(2,1)
  tripadvisorReviewCount  Int?
  tripadvisorUrl          String?          // attribution link required by TA ToS
  // External platform ratings — populated by Playwright-based enrichers.
  googleRating            Decimal? @db.Decimal(2,1)
  googleReviewCount       Int?
  googleUrl               String?  @db.VarChar(500)
  yelpRating              Decimal? @db.Decimal(2,1)
  yelpReviewCount         Int?
  yelpUrl                 String?  @db.VarChar(500)
  // OpenPizzaMap composite score (0.00–10.00). Computed from external + community signals.
  // Decimal(4,2) so the bayesian formula keeps 2 decimals — Decimal(3,1)
  // collapsed 9.06 / 9.07 to the same stored value, masking algorithm changes.
  opmRating               Decimal? @db.Decimal(4,2)
  opmRatingSource         String?  @db.VarChar(20)   // "external" | "community" | "blend"
  // Enrichment pipeline (docs/enrichment-pipeline.md). googlePlaceId is the
  // canonical identity once a row has been through the new flow — unique
  // across the table. Legacy rows stay null until a backfill runs.
  // enrichmentVersion bumps when the pipeline's logic changes in a way that
  // requires re-running; lets a future backfill target rows by version
  // without a "have we processed" boolean.
  googlePlaceId           String?  @unique @db.VarChar(64)
  googlePlaceUrl          String?  @db.VarChar(500)
  enrichmentVersion       Int      @default(0)
  status        PlaceStatus @default(active)
  slug          String?     @unique
  cityId        Int?
  cityRef       City?       @relation(fields: [cityId], references: [id])
  faqs          Faq[]
  sources       PlaceSource[]
  descriptionHtml String?   @db.LongText
  heroImageUrl  String?
  seoTitle      String?
  seoDescription String?    @db.VarChar(200)
  isVisible     Boolean     @default(true)
  // Track 2 (docs/track2-photo-gallery.md): timestamp of last Playwright
  // gallery scrape. Drives the yearly refresh queue + initial-backfill
  // filter. Null = never scraped (eligible for first-ever scrape);
  // older than 365 days = eligible for refresh.
  galleryLastScrapedAt DateTime?
  // External review snapshots (up to 5 per source) — cached so the /place
  // page can render them inline without an outbound API call. JSON shape:
  //   [{ author, rating, text, relativeTime, profilePhoto?, lang? }, ...]
  // Refresh cadence handled by maintenance.js; missing = never fetched.
  googleReviewsJson        String?  @db.Text
  googleReviewsFetchedAt   DateTime?
  // Per-star ratings distribution scraped from the public Google Maps DOM
  // (the Places API doesn't expose it). JSON shape: [c5, c4, c3, c2, c1]
  // where cN is the number of N-star reviews. Sum should equal
  // googleReviewCount within a small drift. Refreshed monthly by the
  // scrape-google-ratings-dist.js enrichment job.
  googleRatingsDistribution  Json?
  googleRatingsScrapedAt     DateTime?
  tripadvisorReviewsJson   String?  @db.Text
  tripadvisorReviewsFetchedAt DateTime?
  // Per-star ratings distribution scraped from the public TripAdvisor
  // restaurant page. Same JSON shape as googleRatingsDistribution:
  // [c5, c4, c3, c2, c1]. Filled by scrape-tripadvisor.js on opm-runner.
  tripadvisorRatingsDistribution  Json?
  tripadvisorRatingsScrapedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  styles        PlaceStyle[]
  visits        Visit[]
  favorites     Favorite[]
  reviews       Review[]
  images        PlaceImage[]
  externalReviews ExternalReview[]

  @@index([city])
  @@index([lat])
  @@index([lng])
  @@index([lat, lng])
  @@index([tripadvisorLocationId])
}

// Gallery photos per Place — populated by the Track 2 Playwright Google
// Maps scraper. Up to 10 rows per Place; position drives ordering and
// hero-photo defaulting (position=1 is the default hero unless
// Place.heroImageUrl was admin-pinned to something else).
//
// Why the columns:
//   - source: 'google' | 'legacy' | 'tripadvisor' | 'website' | 'submitted'
//     so future sources can drop rows in without schema migration
//   - sourceRef: the stable Google photo ID parsed out of the lh3 URL,
//     used by the unique constraint below to dedup on re-scrape
//   - sourceUrl: original signed lh3 URL we downloaded from. Kept for
//     audit + future reprocessing. Note that signed lh3 URLs expire in
//     minutes per the 2026-05-23 Track 1 regression — this column is
//     historical, not usable for re-downloads
//   - width/height/bytes: nullable, populated by the download phase
//     after sharp reads dimensions. Used by the carousel UI to set
//     img dimensions and prevent layout shift
//   - isHidden: admin-set "hide forever" flag. Survives re-scrapes
//     because the dedup unique constraint matches on sourceRef
model PlaceImage {
  id          Int       @id @default(autoincrement())
  placeId     Int
  position    Int                            // 1..10, ordering within the place
  localPath   String    @db.VarChar(255)     // /uploads/places/{placeId}/{position}.{ext}
  source      String    @db.VarChar(20)
  sourceRef   String?   @db.VarChar(255)     // Google photo ID for dedup-on-rescrape
  sourceUrl   String?   @db.VarChar(500)     // original signed URL (audit only)
  width       Int?
  height      Int?
  bytes       Int?
  isHidden    Boolean   @default(false)
  scrapedAt   DateTime  @default(now())
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, position])
  @@unique([placeId, sourceRef])
}

// Scraped external reviews (Google + TripAdvisor), promoted from the
// Place.*ReviewsJson blobs to first-class rows — same pattern as PlaceImage.
// Each row owns its position + isHidden so admin reorder/hide survives the
// monthly re-scrape: the scraper upserts on (placeId, source, dedupKey) and
// preserves position/isHidden for rows that already exist.
//
//   - source: 'google' | 'tripadvisor'
//   - position: display order within (placeId, source); 1-based
//   - dedupKey: stable identity for re-scrape merge = sha1(author|text-prefix)
//     (the public Maps/TA DOM gives no durable review id)
//   - isHidden: admin "hide from the public page forever" flag
//   - publishedAt/profilePhoto/lang: nullable, only some sources populate them
model ExternalReview {
  id           Int       @id @default(autoincrement())
  placeId      Int
  source       String    @db.VarChar(20)
  position     Int
  author       String?   @db.VarChar(191)
  rating       Decimal?  @db.Decimal(2, 1)
  text         String?   @db.Text
  relativeTime String?   @db.VarChar(60)
  profilePhoto String?   @db.VarChar(500)
  publishedAt  DateTime?
  lang         String?   @db.VarChar(10)
  isHidden     Boolean   @default(false)
  dedupKey     String    @db.VarChar(191)
  scrapedAt    DateTime  @default(now())
  place        Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, source, position])
  @@unique([placeId, source, dedupKey])
}

model Visit {
  id        Int      @id @default(autoincrement())
  userId    Int
  placeId   Int
  createdAt DateTime @default(now())
  // User-supplied month-precision "when did you actually visit". Drives
  // the passport-stamp date display + future time-based discovery
  // ("places visited in 2026"). Null fallback to createdAt so legacy
  // rows still render a date.
  visitedAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([placeId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  placeId   Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([placeId])
  @@index([userId])
}

// Community review of a Place. The four category scores are 0.0–5.0 in
// 0.5 steps (validation enforced at the API layer, not the DB — the DB
// just stores a Float). The OPM rating algorithm in
// src/services/opm-rating.js consumes (avg of the 4 categories) × 2 to
// get a 0–10 contribution, then bayesian-blends it with external signals.
//
// Unique (placeId, userId): one review per user per place. Re-submissions
// edit the existing row instead of creating new ones, so a user can
// adjust their rating after a return visit.
model Review {
  id        Int      @id @default(autoincrement())
  placeId   Int
  userId    Int
  pizza     Float                       // 0.0–5.0 in 0.5 steps
  local     Float                       // ditto
  servicio  Float                       // ditto
  precio    Float                       // ditto
  comment   String?  @db.VarChar(500)
  isVisible Boolean  @default(true)     // moderation hatch
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // User-supplied month-precision "when did you actually visit" — same
  // semantics as Visit.visitedAt. The review modal will capture this
  // alongside the 4 category scores so the date in the review card
  // reflects the visit, not the write moment.
  visitedAt DateTime?

  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([placeId, userId])
  @@index([placeId])
  @@index([userId])
  @@index([createdAt])
}

model Country {
  code          String   @id @db.Char(2)
  name          String?
  slug          String?  @unique
  introHtml     String?  @db.LongText
  heroImageUrl  String?
  seoTitle      String?
  seoDescription String? @db.VarChar(200)
  isVisible     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isVisible])
}

model City {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String
  countryCode   String   @db.Char(2)
  introHtml     String?  @db.LongText
  heroImageUrl  String?
  seoTitle      String?
  seoDescription String? @db.VarChar(200)
  isVisible     Boolean  @default(false)
  // Stamp icon slug — drives the passport-stamp illustration on the
  // /me visited section + city-page hero. Two formats:
  //   "svg:colosseum"          → renders /public/img/stamps/colosseum.svg
  //   "mingcute:tower-2-line"  → renders via iconify-icon web component
  // Null = falls through to category-based fallback in render code.
  iconSlug      String?  @db.VarChar(80)
  // Geo + metro grouping for the city-hub "Near {city}" Tier 2 query.
  // lat/lng are the city centroid (geocoded once via Nominatim).
  // metroRadiusKm overrides the default 40km when null; tuneable per
  // city via admin UI for outliers (Naples = 60km to grab Caiazzo).
  // region holds the canonical admin_level_2 string that places in
  // this city report — used for Tier 2 region-match alongside radius.
  lat           Float?
  lng           Float?
  region        String?
  metroRadiusKm Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  places        Place[]
  faqs          Faq[]

  @@unique([countryCode, slug])
  @@index([countryCode])
  @@index([isVisible])
}

enum FaqScope {
  global
  country
  city
  place
}

model Faq {
  id           Int      @id @default(autoincrement())
  scope        FaqScope
  countryCode  String?  @db.Char(2)
  cityId       Int?
  placeId      Int?
  question     String   @db.VarChar(200)
  answerHtml   String   @db.LongText
  sortOrder    Int      @default(0)
  isVisible    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  city         City?    @relation(fields: [cityId], references: [id])
  place        Place?   @relation(fields: [placeId], references: [id])

  @@index([scope])
  @@index([countryCode])
  @@index([cityId])
  @@index([placeId])
  @@index([isVisible])
}

model PlaceSource {
  id      Int    @id @default(autoincrement())
  placeId Int
  source  String @db.VarChar(40)  // "tasteatlas", "thegreat.pizza", "user", etc.
  rank    Int?                    // rank on the source (TasteAtlas position 1, 2, 3…); null for sources without a ranking
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, source])
  @@index([source])
}

model Style {
  id             Int          @id @default(autoincrement())
  slug           String       @unique @db.VarChar(40)
  name           String       @db.VarChar(80)
  shortLabel     String?      @db.VarChar(40)   // chip-sized label, e.g. "Neapolitan"
  introHtml      String?      @db.LongText
  heroImageUrl   String?
  seoTitle       String?
  seoDescription String?      @db.VarChar(200)
  isVisible      Boolean      @default(false)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  places         PlaceStyle[]

  @@index([isVisible])
}

model PlaceStyle {
  placeId   Int
  styleId   Int
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  style     Style    @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@id([placeId, styleId])
  @@index([styleId])
}

model NewsletterSignup {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  source    String?  @db.VarChar(40)
  createdAt DateTime @default(now())
}

model Page {
  id            Int      @id @default(autoincrement())
  key           String   @unique @db.VarChar(60)
  title         String   @db.VarChar(120)
  bodyHtml      String   @db.LongText
  seoTitle      String?
  seoDescription String? @db.VarChar(200)
  isVisible     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isVisible])
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   @db.LongText
  expiresAt DateTime

  @@index([expiresAt])
}

model Submission {
  id               Int              @id @default(autoincrement())
  userId           Int
  type             SubmissionType
  targetPlaceId    Int?
  payloadJson      String
  status           SubmissionStatus @default(pending)
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  reviewedAt       DateTime?
  reviewedByUserId Int?
  reviewedBy       User?            @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])
  user             User             @relation("UserSubmissions", fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([reviewedByUserId], map: "Submission_reviewedByUserId_fkey")
  @@index([userId], map: "Submission_userId_fkey")
}

// Cache for EnrichmentProvider responses. (provider, queryHash) is the
// canonical key; queryHash is sha256("name|city|country") to absorb
// case/whitespace variants. responseJson is the raw provider payload —
// what the next pipeline run reads back when the same query repeats. TTL
// of 90 days keeps it fresh enough without re-charging Google's API.
model EnrichmentCache {
  id           Int      @id @default(autoincrement())
  provider     String   @db.VarChar(20)
  queryHash    String   @db.VarChar(64)
  responseJson String   @db.LongText
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([provider, queryHash])
  @@index([expiresAt])
}

enum UserRole {
  user
  admin
}

enum PlaceStatus {
  active
  closed
  temp_closed
}

enum SubmissionType {
  new_place
  edit_place
}

enum SubmissionStatus {
  pending
  approved
  rejected
}
