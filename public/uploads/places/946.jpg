            src="https://www.pizzanapoletana.org/lang/it/it_validation.js"></script>
        
                <script>
            $(document).ready(function () {
                $('select.training_base_select').change(function () {
                    var data_extra_training_stampata = $('select.training_base_select').find(':selected').data('extra_tr_data');
                    $('.advanced_training').html(data_extra_training_stampata);

                    var advanced_training_avviso_stampato = $('select.training_base_select').find(':selected').data('advanced_training_data');
                    $('.informativa_advanced_training').html(advanced_training_avviso_stampato);

                    var extra_stage_avviso_stampato = $('select.training_base_select').find(':selected').data('extra_stage_si_no');
                    $('.informativa_extra_stage').html(extra_stage_avviso_stampato);
                });

                $('#advanced_training').change(() => {
                    if ($('#advanced_training').is(':checked'))
                        $('#select_at_language').css('display', 'block');
                    else
                        $('#select_at_language').css('display', 'none');
                });
            });

        </script>




        


    <!-- Bottoni + e - degli accordion in club amici -->
    <script>
        function toggleIcon(e) {
            $(e.target)
                .prev('.panel-heading')
                .find(".more-less")
                .toggleClass('glyphicon-plus glyphicon-minus');
        }
        $('.panel-group').on('hidden.bs.collapse', toggleIcon);
        $('.panel-group').on('shown.bs.collapse', toggleIcon);
    </script>


