    <script> //Bottone torna su
        $(function () {
            $(window).scroll(function () {
                if ($(this).scrollTop() != 0) {
                    //se non siamo in cima alla pagina
                    $('#top').fadeIn(); //faccio apparire il box
                } else {
                    //altrimenti (il visitatore è in cima alla pagina scrollTop = 0)
                    $('#top').fadeOut();//Il box scompare
                }
            });//Allo scroll function

            $('#top').click(function () {
                //Se clicco sul box torno su (scrollTop:0) con un timing di animazione.
                $('body,html').animate({ scrollTop: 0 }, 800);
            });//Click

        });//DOM
    </script>


            <!-- Load more -->
        <script>
            var categoria = "no";
            var tag = "no";
            var track_page = 1; //track user click as page number, righ now page number 1
            load_contents(track_page); //load content

            $("#load_more_button").click(function (e) { //user clicks on button
                track_page++; //page number increment everytime user clicks load button
                load_contents(track_page); //load content
            });

            //Ajax load function
            function load_contents(track_page) {
                $('.fa-spinner').show(); //show loading image

                $.post('/sk_carica_news_jquery.php', { 'page': track_page, 'cat': categoria, 'tag': tag }, function (data) {

                    if (data.trim().length == 0) {
                        //display text and disable load button if nothing to load
                        $("#load_more_button").text("Non ci sono news precedenti!").prop("disabled", true);
                    }

                    $("#results").append(data); //append data into #results element

                    //scroll page to button element


                    //hide loading image
                    $('.fa-spinner').hide(); //hide loading image once data is received
                });
            }
        </script>
        
        <script src="https://www.pizzanapoletana.org/js/vanilla-calendar.js"></script>

        <!-- datepicker jquery -->
                <link rel="stylesheet" href="//code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
        <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
        <script
            src="https://www.pizzanapoletana.org/lang/it/datepicker-it.js"></script>
        <script>
            $(function () {
                $(".datepicker").datepicker({
                    changeMonth: true,
                    changeYear: true,
                    showButtonPanel: true,
                    yearRange: "-100:+1"
                });
            });

            $(function () {
                $("#check_in, #check_out").datepicker({
                    changeMonth: true,
                    changeYear: true,
                    showButtonPanel: true,
                    yearRange: "0:+2",
                    minDate: 0,
                    beforeShow: customRange
                });
            });

            function customRange(input) {
                if (input.id == 'check_out') {
                    return {
                        minDate: jQuery('#check_in').datepicker("getDate")
                    };
                } else if (input.id == 'check_in') {
                    return {
                        maxDate: jQuery('#check_out').datepicker("getDate")
                    };
                }
            }

            // date corso PNPUG in sede
            const div_calendar_ppug_in_sede = document.getElementById('bigCalendar_ppug_in_sede');
            if (div_calendar_ppug_in_sede && array_date_escluse) {
                let datesAvailableFormatted = [];

                // OPEN NEXT YEAR AFTER AUGUST
                let endYear = (04 >= 8) ? '2027' : '2026';

                let start = new Date("2026-01-01");
                let end = new Date(endYear + "-12-31");

                let dates = [];

                while (start <= end) {
                    let year = start.getFullYear();
                    let month = (start.getMonth() + 1).toString().padStart(2, '0');
                    let day = start.getDate().toString().padStart(2, '0');

                    dates.push(`${year}-${month}-${day}`);

                    start.setDate(start.getDate() + 1);
                }

                if (typeof array_date_escluse !== 'undefined') {
                    dates.forEach(el => {
                        if (!array_date_escluse.includes(el))
                            datesAvailableFormatted.push({ date: el, others: false });
                    })
                }

                let selectedDate = null;

                let calendar_ppug_in_sede = new VanillaCalendar({
                    selector: "#bigCalendar_ppug_in_sede",
                    pastDates: false,
                    datesFilter: true,
                    availableDates: datesAvailableFormatted,
                    enabled: false,
                    onSelect: function (data, elem) {
                        selectedDate = data;
                    },
                    allowClick: true,
                    invertDates: false,
                    afterLoad: () => {
                        // Check if dates must be inverted. Compare with select input

                        // Get active dates from new calendar
                        let activeDays = [];
                        document.querySelectorAll('.vanilla-calendar-date').forEach(el => {
                            if (el.dataset.calendarStatus) {
                                let day = el.dataset.calendarDate

                                // Convert day format
                                // From: Tue Feb 07 2023 11:59:18 GMT+0100 (Central European Standard Time)
                                // To: 2023-07-01
                                let date = new Date(day);
                                let dayFormatted = date.getFullYear() + '-' + String(date.getMonth() + 1).padStart('2', 0) + '-' + String(date.getDate()).padStart('2', 0);

                                activeDays.push(dayFormatted)
                            }
                        })

                        // Get active days from array_date_escluse and compare the values
                        let mustInvert = false;

                        activeDays.forEach(el => {
                            if (array_date_escluse.includes(el)) {
                                mustInvert = true;
                                return;
                            }
                        })

                        if (!mustInvert)
                            return;

                        // A date that should be active was detected. Invert the dates
                        calendar_ppug_in_sede = new VanillaCalendar({
                            selector: "#bigCalendar_ppug_in_sede",
                            pastDates: false,
                            datesFilter: true,
                            availableDates: datesAvailableFormatted,
                            enabled: false,
                            onSelect: function (data, elem) {
                                selectedDate = data;
                            },
                            allowClick: true,
                            invertDates: false,
                            afterLoad: () => { },
                        });

                        console.log('Information: Calendar dates inverted')
                    }
                });

                                    if (typeof calendar_ppug_in_sede !== 'undefined') {
                        calendar_ppug_in_sede.set(
                            {
                                months: ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'],
                                shortWeekday: ['Dom', 'Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab'],
                            }
                        );
                    }
                    
                // Add button event to set date
                const ppug_in_sede_set_date = document.getElementById('ppug_in_sede_set_date');

                if (ppug_in_sede_set_date) {
                    ppug_in_sede_set_date.addEventListener('click', () => {
                        if (selectedDate) {
                            const lang = 'it';
                            let newDate = null;

                            // Adjust format:
                            if (lang == 'en') {
                                // From: 2023-01-30 TO 01/30/2023
                                let dateParts = selectedDate.data.date.split('-');
                                newDate = `${dateParts[1]}/${dateParts[2]}/${dateParts[0]}`;
                            } else {
                                // From: 2023-01-30 TO 30/01/2023
                                newDate = selectedDate.data.date.split('-').reverse().join('/');
                            }

                            // Set date in form calendar
                            const formCalendar = $('#data_PNPUG');
                            formCalendar.val(newDate);
                            show_disponibilita_PNPUG(newDate);
                        }
                    });
                }
            }
            // end date corso PNPUG in sede

            // date corso PNPUG in sede
            $(".datepicker_data_PNPUG").datepicker({
                beforeShowDay: function (date) {
                    var string = jQuery.datepicker.formatDate('yy-mm-dd', date);

                    return [array_date_escluse.indexOf(string) == -1]
                },
                changeMonth: true,
                changeYear: true,
                showButtonPanel: true,
                // decommentare questo parametro quando le date saranno implementate con le ripetizioni.
                //yearRange: "0:+1",
                minDate: 2,
                // eliminare questo parametro quando le date saranno implementate con le ripetizioni
                maxDate: new Date('2027-12-31')
            });

            // PPUG ONLINE
            // datesAvailable is defined in funct_school.php
            $(".availableDatesPPUG").datepicker({
                beforeShowDay: function (date) {
                    var string = jQuery.datepicker.formatDate('yy-mm-dd', date);
                    return [datesAvailable.indexOf(string) != -1]
                },
                changeMonth: true,
                changeYear: true,
                showButtonPanel: true,
                // decommentare questo parametro quando le date saranno implementate con le ripetizioni.
                yearRange: "0:+1",
                minDate: 1,
                // eliminare questo parametro quando le date saranno implementate con le ripetizioni
                maxDate: new Date('2026-12-31'),
            });

            let datesAvailableFormatted = [];

            if (typeof datesAvailable !== 'undefined') {
                datesAvailable.forEach(el => {
                    datesAvailableFormatted.push({ date: el, others: false });
                });
            }

            const div_availableDatesCalendar = document.getElementById('availableDatesCalendar');

            if (div_availableDatesCalendar) {
                let availableDatesCalendar = new VanillaCalendar({
                    selector: "#availableDatesCalendar",
                    pastDates: false,
                    datesFilter: true,
                    availableDates: datesAvailableFormatted,
                    enabled: false,
                });

                
                    if (typeof availableDatesCalendar !== 'undefined') {

                        availableDatesCalendar.set(
                            {
                                months: ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'],
                                shortWeekday: ['Dom', 'Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab'],
                            }
                        );

                    }

                                }

            // Replicate calendar to input
            $('#availableDatesPPUG').change(() => {

                let format = $('#availableDatesPPUG').datepicker('option', 'dateFormat');

                let newDay = $('#availableDatesPPUG').val();

                let newDayOtherFormat = '';

                if (format == 'dd/mm/yy') {
                    newDayOtherFormat = newDay.split("/").reverse().join("-");
                } else if (format == 'mm/dd/yy') {
                    let partsOfDate = newDay.split("/");
                    newDayOtherFormat = partsOfDate[2] + '-' + partsOfDate[0] + '-' + partsOfDate[1];
                } else {
                    alert('Wrong date format. Please contact administrator.');
                }

                $('#data_corso_avanzato option').each(function () {

                    if ($(this)[0].innerHTML == newDayOtherFormat) {
                        $('#data_corso_avanzato').val($(this)[0].value);
                    }
                });

            });


        </script>

