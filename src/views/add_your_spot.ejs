<%
  const stylesPayload = JSON.stringify(styles || []);
%>
<%- include("layout", {
  title: "Add your spot",
  user,
  leaflet: false,
  bodyClass: "addspot-page",
  body: String.raw`
    <section class="addspot" data-addspot-root>
      <div class="addspot__chat" data-addspot-chat aria-live="polite">
        <ol class="addspot__log" data-addspot-log></ol>
        <div class="addspot__typing" data-addspot-typing hidden>
          <span></span><span></span><span></span>
        </div>
      </div>

      <form class="addspot__compose" data-addspot-form autocomplete="off">
        <label for="addspot-input" class="visually-hidden">Your reply</label>
        <textarea
          id="addspot-input"
          name="message"
          rows="1"
          placeholder="Reply to OpenPizzaMap…"
          maxlength="2000"
          autocomplete="off"
          enterkeyhint="send"
          data-addspot-input
          required
        ></textarea>
        <button type="submit" class="addspot__send" data-addspot-send aria-label="Send" disabled>
          <span class="material-symbols-rounded" aria-hidden="true">arrow_upward</span>
        </button>
      </form>

      <div class="addspot__error" data-addspot-error hidden></div>
    </section>

    <script type="application/json" id="addspot-styles">${stylesPayload}</script>
    <script src="/public/js/typewriter-chat.js?v=${assetVersion || ''}" defer></script>
    <script src="/public/js/add-your-spot.js?v=${assetVersion || ''}" defer></script>
  `
}) %>
