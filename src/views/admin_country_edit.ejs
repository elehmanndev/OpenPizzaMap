<%- include("layout", { title: `Admin · Country · ${country.code}`, user, leaflet: false, body: String.raw`
  <h1>Edit country: ${escapeHtml(country.code)}</h1>
  <form method="post" action="/admin/countries/${encodeURIComponent(country.code)}" class="card" style="display:grid; gap:12px;">
    <label>
      <div class="small">Name</div>
      <input name="name" value="${escapeAttr(country.name || "")}" />
    </label>
    <label>
      <div class="small">Hero image URL</div>
      <input name="heroImageUrl" value="${escapeAttr(country.heroImageUrl || "")}" placeholder="https://..." />
    </label>
    <label>
      <div class="small">Visible</div>
      <input type="checkbox" name="isVisible" value="1" ${country.isVisible ? "checked" : ""} />
    </label>
    <div>
      <div class="small">Intro</div>
      <div id="editor" style="background: var(--c-surface);"></div>
      <input type="hidden" name="introHtml" id="introHtml" />
    </div>
    <div class="row">
      <div style="flex:1;">
        <button type="submit">Save</button>
      </div>
      <div style="flex:1;">
        <a class="btn" href="/admin/countries">Back</a>
      </div>
    </div>
  </form>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("introHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (!editorEl || !input || !form) return;

      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(country.introHtml || "")};

      form.addEventListener("submit", function () {
        input.value = quill.root.innerHTML || "";
      });
    })();
  </script>
` }) %>
