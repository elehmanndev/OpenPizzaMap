<%- include("layout", { title: `Admin · FAQ · ${faq.id || "new"}`, user, leaflet: false, body: String.raw`
  <h1>${faq.id ? "Edit FAQ" : "New FAQ"}</h1>
  <form method="post" action="${faq.id ? `/admin/faqs/${faq.id}` : "/admin/faqs"}" class="card" style="display:grid; gap:12px;">
    <label>
      <div class="small">Scope</div>
      <select name="scope" required>
        ${["global","country","city","place"].map(s => `<option value="${s}" ${(faq.scope||"")==s ? "selected" : ""}>${s}</option>`).join("")}
      </select>
    </label>
    <label>
      <div class="small">Country code (for scope=country or to scope content)</div>
      <input name="countryCode" value="${escapeAttr(faq.countryCode || "")}" placeholder="ES" />
    </label>
    <label>
      <div class="small">City ID (for scope=city)</div>
      <input name="cityId" value="${escapeAttr(faq.cityId || "")}" placeholder="123" />
    </label>
    <label>
      <div class="small">Place ID (for scope=place)</div>
      <input name="placeId" value="${escapeAttr(faq.placeId || "")}" placeholder="456" />
    </label>
    <label>
      <div class="small">Question</div>
      <input name="question" value="${escapeAttr(faq.question || "")}" required />
    </label>
    <label>
      <div class="small">Sort order</div>
      <input name="sortOrder" type="number" value="${typeof faq.sortOrder === "number" ? faq.sortOrder : 0}" />
    </label>
    <label>
      <div class="small">Visible</div>
      <input type="checkbox" name="isVisible" value="1" ${faq.isVisible ? "checked" : ""} />
    </label>
    <div>
      <div class="small">Answer</div>
      <div id="editor" style="background: var(--c-surface);"></div>
      <input type="hidden" name="answerHtml" id="answerHtml" />
    </div>
    <div class="row">
      <div style="flex:1;">
        <button type="submit">Save</button>
      </div>
      <div style="flex:1;">
        <a class="btn" href="/admin/faqs">Back</a>
      </div>
    </div>
  </form>

  ${faq.id ? `
    <form method="post" action="/admin/faqs/${faq.id}/delete" onsubmit="return confirm('Delete this FAQ?')">
      <button type="submit">Delete FAQ</button>
    </form>
  ` : ""}

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("answerHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (!editorEl || !input || !form) return;

      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(faq.answerHtml || "")};

      form.addEventListener("submit", function () {
        input.value = quill.root.innerHTML || "";
      });
    })();
  </script>
` }) %>
