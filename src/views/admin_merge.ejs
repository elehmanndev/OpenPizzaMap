<%
// Human-readable labels for the schema columns. Internal field names
// like `addressLine` / `stylesJson` are not surfaced to the page — Eric
// asked explicitly for a non-technical view.
const FIELD_LABELS = {
    name: "Name",
    addressLine: "Address",
    region: "Region",
    postalCode: "Postal code",
    phone: "Phone",
    websiteUrl: "Website",
    googleMapsUrl: "Google Maps link",
    instagramUrl: "Instagram",
    facebookUrl: "Facebook",
    openingHours: "Opening hours",
    googlePlaceId: "Google Place ID",
    googlePlaceUrl: "Google Place URL",
    googleRating: "Google rating",
    googleReviewCount: "Google review count",
    tripadvisorLocationId: "TripAdvisor location",
    tripadvisorRanking: "TripAdvisor ranking",
    tripadvisorRating: "TripAdvisor rating",
    tripadvisorReviewCount: "TripAdvisor review count",
    tripadvisorUrl: "TripAdvisor link",
    yelpRating: "Yelp rating",
    yelpReviewCount: "Yelp review count",
    yelpUrl: "Yelp link",
    descriptionHtml: "Description",
    heroImageUrl: "Hero image",
    seoTitle: "SEO title",
    seoDescription: "SEO description",
    stylesJson: "Pizza styles",
    priceLevel: "Price level",
    enrichmentVersion: "Enrichment version",
};
const labelFor = (f) => FIELD_LABELS[f] || f;
const fmt = (v) => {
    if (v == null) return "—";
    const s = String(v).trim();
    if (s === "") return "—";
    if (s.length > 80) return s.slice(0, 77) + "…";
    return s;
};
// Friendly summary line for the "also moves" pill row.
const counts = plan ? {
    sources: plan.sourcesToCopy.length,
    photos: plan.imagesToMove.length,
    photosSkipped: plan.imagesSkipped.length,
    reviews: plan.reviewsToMove.length,
    reviewsSkipped: plan.reviewsSkipped.length,
    visits: plan.visitsToMove.length,
    favorites: plan.favoritesToMove.length,
    faqs: plan.faqsToMove.length,
} : null;
%>
<%- include("layout", { title: "Admin · Merge duplicates", user, leaflet: false, body: String.raw`
  <style>
    .merge-page { max-width: 980px; margin: 0 auto; padding: 12px 4px; }
    .merge-page h1 { margin: 12px 4px 8px; font-size: 28px; font-weight: 700; letter-spacing: -0.01em; }
    .merge-page .lede { color: var(--c-muted); margin: 0 4px 20px; font-size: 14px; line-height: 1.5; max-width: 640px; }

    .merge-find {
      display: flex; flex-wrap: wrap; gap: 12px; align-items: end;
      padding: 16px; border: 1px solid var(--c-border); border-radius: 14px;
      background: var(--c-surface);
    }
    .merge-find > div { flex: 1 1 200px; min-width: 0; }
    .merge-find label {
      display: block; font-size: 12px; font-weight: 600; color: var(--c-muted);
      margin-bottom: 6px; letter-spacing: 0.02em; text-transform: uppercase;
    }
    .merge-find input { font-size: 18px; font-weight: 600; padding: 12px 14px; }
    .merge-find button {
      background: var(--c-text); color: var(--c-bg); font-weight: 600;
      padding: 12px 24px; min-width: 120px;
    }

    .merge-banner {
      padding: 14px 16px; border-radius: 12px; margin: 16px 0;
      display: flex; gap: 12px; align-items: flex-start;
    }
    .merge-banner.error { background: rgba(192, 57, 43, 0.08); border: 1px solid rgba(192, 57, 43, 0.3); color: var(--c-error); }
    .merge-banner.success { background: rgba(52, 199, 89, 0.08); border: 1px solid rgba(52, 199, 89, 0.3); color: #1f7a3a; }
    .merge-banner .icon { font-size: 20px; line-height: 1; flex: none; }
    .merge-banner .body { flex: 1; }
    .merge-banner .body strong { display: block; font-size: 15px; margin-bottom: 2px; }
    .merge-banner .body p { margin: 0; font-size: 14px; line-height: 1.45; }

    .merge-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 16px 0; }
    @media (max-width: 640px) { .merge-pair { grid-template-columns: 1fr; } }

    .place-card {
      border: 1px solid var(--c-border); border-radius: 14px; padding: 16px 18px;
      background: var(--c-surface); position: relative;
    }
    .place-card.keep { border-color: rgba(52, 199, 89, 0.45); box-shadow: 0 0 0 3px rgba(52, 199, 89, 0.08); }
    .place-card.drop { border-color: rgba(192, 57, 43, 0.4); }
    .place-card .tag {
      display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase; padding: 3px 8px; border-radius: 6px; margin-bottom: 10px;
    }
    .place-card.keep .tag { background: rgba(52, 199, 89, 0.15); color: #1f7a3a; }
    .place-card.drop .tag { background: rgba(192, 57, 43, 0.12); color: var(--c-accent); }
    .place-card .place-name { font-size: 20px; font-weight: 700; line-height: 1.2; margin: 0 0 4px; word-break: break-word; }
    .place-card .place-name a { color: inherit; text-decoration: none; border-bottom: 1px dashed var(--c-border); }
    .place-card .place-name a:hover { border-bottom-style: solid; }
    .place-card .place-meta { font-size: 13px; color: var(--c-muted); }
    .place-card .place-id { font-family: 'SF Mono', ui-monospace, monospace; font-size: 12px; color: var(--c-muted); margin-top: 8px; }
    .place-card.drop .place-name { opacity: 0.7; }

    .changes-block { margin: 24px 0; }
    .changes-block h2 { margin: 0 4px 12px; font-size: 16px; font-weight: 700; letter-spacing: -0.005em; }
    .changes-block h2 .count { color: var(--c-muted); font-weight: 500; margin-left: 8px; font-size: 14px; }
    .changes-empty {
      padding: 18px 16px; border: 1px dashed var(--c-border); border-radius: 12px;
      color: var(--c-muted); font-size: 14px; text-align: center;
    }
    .change-row {
      padding: 12px 16px; border: 1px solid var(--c-border); border-radius: 12px;
      background: var(--c-surface); margin-bottom: 8px;
    }
    .change-row .field { font-size: 12px; font-weight: 700; color: var(--c-muted); letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 6px; }
    .change-row .ba { display: grid; grid-template-columns: 1fr auto 1fr; gap: 10px; align-items: center; font-size: 14px; }
    @media (max-width: 540px) {
      .change-row .ba { grid-template-columns: 1fr; gap: 4px; }
      .change-row .arrow { display: none; }
    }
    .change-row .before { color: var(--c-muted); text-decoration: line-through; word-break: break-word; }
    .change-row .arrow { color: var(--c-muted); font-size: 16px; }
    .change-row .after { color: var(--c-text); font-weight: 600; word-break: break-word; }
    .change-row .reason {
      display: inline-block; margin-top: 8px; font-size: 11px; color: var(--c-muted);
      background: var(--c-input-bg); padding: 2px 8px; border-radius: 6px;
    }

    .moves-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 8px; margin: 8px 0;
    }
    .move-pill {
      padding: 14px 12px; border: 1px solid var(--c-border); border-radius: 12px;
      background: var(--c-surface); text-align: center;
    }
    .move-pill .n { font-size: 26px; font-weight: 700; line-height: 1; }
    .move-pill .lbl { font-size: 12px; color: var(--c-muted); margin-top: 4px; }
    .move-pill .sub { font-size: 11px; color: var(--c-muted); margin-top: 2px; }
    .move-pill.zero .n { color: var(--c-muted); opacity: 0.5; }

    .apply-bar {
      margin: 24px 0 16px; padding: 18px; border-radius: 14px;
      background: linear-gradient(135deg, rgba(192, 57, 43, 0.04), rgba(192, 57, 43, 0.01));
      border: 1px solid rgba(192, 57, 43, 0.18);
      display: flex; flex-wrap: wrap; gap: 14px; align-items: center; justify-content: space-between;
    }
    .apply-bar .note { font-size: 13px; color: var(--c-muted); max-width: 480px; line-height: 1.4; }
    .apply-bar button {
      background: var(--c-accent); color: #fff; font-weight: 600; padding: 14px 22px;
      font-size: 15px; min-width: 200px;
    }
    .apply-bar button:hover { background: var(--c-accent-strong); }

    /* Candidate-duplicate queue */
    .dup-queue { margin: 24px 0; }
    .dq-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin: 0 4px 12px; flex-wrap: wrap; }
    .dq-head h2 { margin: 0; font-size: 16px; font-weight: 700; }
    .dq-head h2 .count { color: var(--c-muted); font-weight: 500; margin-left: 8px; font-size: 14px; }
    .dq-refresh { font-size: 12px; color: var(--c-muted); text-decoration: none; border-bottom: 1px dashed var(--c-border); }
    .dq-refresh:hover { color: var(--c-text); }
    .dq-row {
      display: flex; gap: 12px; align-items: center; justify-content: space-between;
      padding: 12px 16px; border: 1px solid var(--c-border); border-radius: 12px;
      background: var(--c-surface); margin-bottom: 8px;
    }
    .dq-row.flagged { border-color: rgba(192, 57, 43, 0.4); box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.06); }
    .dq-main { min-width: 0; flex: 1; }
    .dq-names { font-size: 15px; font-weight: 600; line-height: 1.3; word-break: break-word; }
    .dq-vs { color: var(--c-muted); font-weight: 400; margin: 0 6px; }
    .dq-drop { color: var(--c-muted); }
    .dq-meta { font-size: 12px; color: var(--c-muted); margin-top: 4px; }
    .dq-flag { color: var(--c-accent); font-weight: 600; }
    .dq-actions { display: flex; gap: 8px; align-items: center; flex: none; }
    .dq-review {
      background: var(--c-text); color: var(--c-bg); font-weight: 600; font-size: 13px;
      padding: 9px 14px; border-radius: 9px; text-decoration: none; white-space: nowrap;
    }
    .dq-review:hover { opacity: 0.85; }
    .dq-actions form { margin: 0; }
    .dq-dismiss {
      background: transparent; border: 1px solid var(--c-border); color: var(--c-muted);
      font-size: 12px; padding: 8px 10px; border-radius: 9px; cursor: pointer; white-space: nowrap;
    }
    .dq-dismiss:hover { border-color: var(--c-accent); color: var(--c-accent); }
    @media (max-width: 540px) {
      .dq-row { flex-direction: column; align-items: stretch; }
      .dq-actions { justify-content: flex-end; }
    }
  </style>
  <div class="merge-page">
    <h1>Merge duplicates</h1>
    <p class="lede">Two places that are actually the same restaurant. Pick which one to keep — the other is hidden and its data folds into the survivor.</p>

    <form method="get" action="/admin/merge" class="merge-find">
      <div>
        <label>Keep this one</label>
        <input type="number" name="survivor" required min="1" value="${escapeAttr(survivor || "")}" placeholder="e.g. 177" />
      </div>
      <div>
        <label>Hide this one</label>
        <input type="number" name="drop" required min="1" value="${escapeAttr(drop || "")}" placeholder="e.g. 1618" />
      </div>
      <div style="flex: 0 0 auto;">
        <label style="visibility: hidden;">.</label>
        <button type="submit" name="action" value="preview">Compare</button>
      </div>
    </form>

    ${queue ? `
      <div class="dup-queue">
        <div class="dq-head">
          <h2>Possible duplicates <span class="count">${queue.pairs.length} pair${queue.pairs.length === 1 ? "" : "s"}</span></h2>
          <a class="dq-refresh" href="/admin/merge?rescan=1">↻ Rescan · ${queue.scanned} places · ${queue.ageMin === 0 ? "just now" : queue.ageMin + "m ago"}</a>
        </div>
        ${queue.pairs.length ? queue.pairs.map(p => `
          <div class="dq-row ${p.flagged ? "flagged" : ""}">
            <div class="dq-main">
              <div class="dq-names">
                <span class="dq-keep">#${p.survivorId} ${escapeHtml(p.survivorName)}</span><span class="dq-vs">+</span><span class="dq-drop">#${p.dropId} ${escapeHtml(p.dropName)}</span>
              </div>
              <div class="dq-meta">
                ${escapeHtml(p.city || "—")}, ${escapeHtml(p.country || "—")} · ${p.distM}m apart · ${escapeHtml(p.why)}${p.flagged ? ` · <span class="dq-flag">⚠ needs review — ${p.flags.map(f => escapeHtml(f.reason)).join("; ")}</span>` : ""}
              </div>
            </div>
            <div class="dq-actions">
              <a class="dq-review" href="/admin/merge?survivor=${p.survivorId}&amp;drop=${p.dropId}">Review →</a>
              <form method="post" action="/admin/merge/dismiss" onsubmit="return confirm('Mark this pair as NOT a duplicate? It will not appear in this list again.')">
                <input type="hidden" name="survivor" value="${p.survivorId}" />
                <input type="hidden" name="drop" value="${p.dropId}" />
                <button type="submit" class="dq-dismiss">Not a dupe</button>
              </form>
            </div>
          </div>
        `).join("") : `<div class="changes-empty">No duplicate candidates right now. 🎉</div>`}
      </div>
    ` : queueError ? `
      <div class="merge-banner error">
        <span class="icon">!</span>
        <div class="body">
          <strong>Couldn't scan for duplicates</strong>
          <p>${escapeHtml(queueError)}</p>
        </div>
      </div>
    ` : ""}

    ${error ? `
      <div class="merge-banner error">
        <span class="icon">!</span>
        <div class="body">
          <strong>Couldn't compare</strong>
          <p>${escapeHtml(error)}</p>
        </div>
      </div>
    ` : ""}

    ${result ? `
      <div class="merge-banner success">
        <span class="icon">✓</span>
        <div class="body">
          <strong>Merged successfully</strong>
          <p>Place #${result.survivorId} absorbed #${result.droppedId}. ${result.fieldsPatched} fields updated, ${result.imagesMoved} photos, ${result.reviewsMoved} reviews, ${result.sourcesCopied} sources moved. The duplicate is now hidden and won't reappear.</p>
        </div>
      </div>
    ` : ""}

    ${plan ? `
      <div class="merge-pair">
        <div class="place-card keep">
          <span class="tag">Keeping</span>
          <h2 class="place-name"><a href="/place/${plan.survivor.id}${plan.survivor.slug ? '/' + plan.survivor.slug : ''}" target="_blank">${escapeHtml(plan.survivor.name)}</a></h2>
          <div class="place-meta">${escapeHtml(plan.survivor.city || "—")}, ${escapeHtml(plan.survivor.country || "—")}</div>
          <div class="place-id">#${plan.survivor.id} · ${plan.survivor.isVisible ? "live" : "hidden"}</div>
        </div>
        <div class="place-card drop">
          <span class="tag">Removing</span>
          <h2 class="place-name"><a href="/place/${plan.drop.id}${plan.drop.slug ? '/' + plan.drop.slug : ''}" target="_blank">${escapeHtml(plan.drop.name)}</a></h2>
          <div class="place-meta">${escapeHtml(plan.drop.city || "—")}, ${escapeHtml(plan.drop.country || "—")}</div>
          <div class="place-id">#${plan.drop.id} · ${plan.drop.isVisible ? "live" : "hidden"}</div>
        </div>
      </div>

      <div class="changes-block">
        <h2>What changes on ${escapeHtml(plan.survivor.name)} <span class="count">${plan.decisions.length} field${plan.decisions.length === 1 ? "" : "s"}</span></h2>
        ${plan.decisions.length ? plan.decisions.map(d => `
          <div class="change-row">
            <div class="field">${escapeHtml(labelFor(d.field))}</div>
            <div class="ba">
              <div class="before">${escapeHtml(fmt(d.before))}</div>
              <div class="arrow">→</div>
              <div class="after">${escapeHtml(fmt(d.after))}</div>
            </div>
            <span class="reason">${escapeHtml(d.reason)}</span>
          </div>
        `).join("") : `<div class="changes-empty">The kept place already has all the better info. Nothing to copy across.</div>`}
      </div>

      <div class="changes-block">
        <h2>Also moving across</h2>
        <div class="moves-grid">
          <div class="move-pill ${counts.photos === 0 ? "zero" : ""}">
            <div class="n">${counts.photos}</div>
            <div class="lbl">Photos</div>
            ${counts.photosSkipped ? `<div class="sub">${counts.photosSkipped} duplicate skipped</div>` : ""}
          </div>
          <div class="move-pill ${counts.reviews === 0 ? "zero" : ""}">
            <div class="n">${counts.reviews}</div>
            <div class="lbl">Community reviews</div>
            ${counts.reviewsSkipped ? `<div class="sub">${counts.reviewsSkipped} skipped</div>` : ""}
          </div>
          <div class="move-pill ${counts.visits === 0 ? "zero" : ""}">
            <div class="n">${counts.visits}</div>
            <div class="lbl">Visits</div>
          </div>
          <div class="move-pill ${counts.favorites === 0 ? "zero" : ""}">
            <div class="n">${counts.favorites}</div>
            <div class="lbl">Favorites</div>
          </div>
          <div class="move-pill ${counts.sources === 0 ? "zero" : ""}">
            <div class="n">${counts.sources}</div>
            <div class="lbl">Source attributions</div>
          </div>
          ${counts.faqs ? `
            <div class="move-pill">
              <div class="n">${counts.faqs}</div>
              <div class="lbl">FAQs</div>
            </div>
          ` : ""}
        </div>
      </div>

      <form method="post" action="/admin/merge" class="apply-bar">
        <input type="hidden" name="survivor" value="${plan.survivor.id}" />
        <input type="hidden" name="drop" value="${plan.drop.id}" />
        <input type="hidden" name="action" value="apply" />
        <div class="note">Hides #${plan.drop.id} from the map and prevents it from being auto-republished. Everything happens in a single transaction — safe to back out by editing manually if needed.</div>
        <button type="submit">Merge &amp; hide #${plan.drop.id}</button>
      </form>
    ` : ""}
  </div>
` }) %>
