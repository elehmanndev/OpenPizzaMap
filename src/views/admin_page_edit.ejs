<%- include("layout", { title: `Admin · Page · ${page.key}`, user, leaflet: false, body: String.raw`
  <h1>Edit page: ${escapeHtml(page.key)}</h1>
  <form method="post" action="/admin/pages/${encodeURIComponent(page.key)}" class="card" style="display:grid; gap:12px;">
    <label>
      <div class="small">Title</div>
      <input name="title" value="${escapeAttr(page.title || "")}" required />
    </label>
    <label>
      <div class="small">Visible</div>
      <input type="checkbox" name="isVisible" value="1" ${page.isVisible ? "checked" : ""} />
    </label>
    <div>
      <div class="small">Body</div>
      <div id="editor" style="background: var(--c-surface);"></div>
      <input type="hidden" name="bodyHtml" id="bodyHtml" />
    </div>
    <div class="row">
      <div style="flex:1;">
        <button type="submit">Save</button>
      </div>
      <div style="flex:1;">
        <a class="btn" href="/admin/pages">Back</a>
      </div>
    </div>
  </form>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("bodyHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (!editorEl || !input || !form) return;

      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(page.bodyHtml || "")};

      form.addEventListener("submit", function () {
        input.value = quill.root.innerHTML || "";
      });
    })();
  </script>
` }) %>
