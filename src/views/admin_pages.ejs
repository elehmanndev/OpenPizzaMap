<%- include("layout", { title: "Admin · Pages", user, leaflet: false, body: String.raw`
  <h1>Pages</h1>
  <div class="card">
    <form method="get" action="/admin/pages/new" class="row">
      <div style="flex:2; min-width:220px;">
        <label>Key</label>
        <input name="key" placeholder="about" />
      </div>
      <div style="flex:1; align-self:end;">
        <button type="submit">Create / edit</button>
      </div>
    </form>
  </div>

  ${pages && pages.length ? pages.map(p => `
    <div class="card">
      <div><strong>${escapeHtml(p.key)}</strong> ${p.isVisible ? "" : "<span class='small'>(hidden)</span>"}</div>
      <div class="small">${escapeHtml(p.title || "")}</div>
      <div style="margin-top:8px;">
        <a class="btn primary" href="/admin/pages/${encodeURIComponent(p.key)}">Edit</a>
      </div>
    </div>
  `).join("") : "<p class=\"small\">No pages yet.</p>"}
` }) %>
