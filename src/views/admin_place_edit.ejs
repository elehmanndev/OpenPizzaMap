<%- include("layout", { title: `Admin · Place · ${place.name}`, user, leaflet: false, body: String.raw`
  <h1>Edit place: ${escapeHtml(place.name)}</h1>
  <div class="small">${escapeHtml(place.city)} · ${escapeHtml(place.country)} · #${place.id}</div>

  <form method="post" action="/admin/places/${place.id}" class="card" style="display:grid; gap:12px; margin-top:12px;">
    <label>
      <div class="small">Slug (optional)</div>
      <input name="slug" value="${escapeAttr(place.slug || "")}" placeholder="sample-place" />
    </label>
    <label>
      <div class="small">Hero image URL</div>
      <input name="heroImageUrl" value="${escapeAttr(place.heroImageUrl || "")}" placeholder="https://..." />
    </label>
    <label>
      <div class="small">Visible</div>
      <input type="checkbox" name="isVisible" value="1" ${place.isVisible ? "checked" : ""} />
    </label>
    <div>
      <div class="small">Description</div>
      <div id="editor" style="background: var(--c-surface);"></div>
      <input type="hidden" name="descriptionHtml" id="descriptionHtml" />
    </div>
    <div class="row">
      <div style="flex:1;">
        <button type="submit">Save</button>
      </div>
      <div style="flex:1;">
        <a class="btn" href="/admin/places">Back</a>
      </div>
    </div>
  </form>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("descriptionHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (!editorEl || !input || !form) return;

      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(place.descriptionHtml || "")};

      form.addEventListener("submit", function () {
        input.value = quill.root.innerHTML || "";
      });
    })();
  </script>
` }) %>
