<%
  const fmtDate = (d) => d ? new Date(d).toISOString().slice(0, 16).replace("T", " ") : "—";
  const ftid = place.googlePlaceId && /^0x[0-9a-f]+:0x[0-9a-f]+$/i.test(place.googlePlaceId);
  const reviewRow = (r) => `
    <div class="ed-rev${r.isHidden ? " is-hidden" : ""}">
      <div class="ed-rev__main">
        <div class="ed-rev__head">
          <strong>${escapeHtml(r.author || "Anonymous")}</strong>
          ${r.rating != null ? `<span class="ed-rev__stars">★ ${Number(r.rating).toFixed(1)}</span>` : ""}
          ${r.relativeTime ? `<span class="muted small">· ${escapeHtml(r.relativeTime)}</span>` : ""}
          ${r.isHidden ? `<span class="ed-tag ed-tag--hidden">hidden</span>` : ""}
        </div>
        <div class="ed-rev__text small">${r.text ? escapeHtml(String(r.text).slice(0, 320)) : '<span class="muted">(no text)</span>'}</div>
      </div>
      <div class="ed-rev__actions">
        <form method="post" action="/admin/places/${place.id}/reviews/${r.id}/move?dir=up"><button type="submit" title="Move up">↑</button></form>
        <form method="post" action="/admin/places/${place.id}/reviews/${r.id}/move?dir=down"><button type="submit" title="Move down">↓</button></form>
        <form method="post" action="/admin/places/${place.id}/reviews/${r.id}/toggle-hidden"><button type="submit">${r.isHidden ? "Show" : "Hide"}</button></form>
      </div>
    </div>`;
%>
<%- include("layout", { title: `Admin · Place · ${place.name}`, user, leaflet: false, bodyClass: "admin-page", body: String.raw`
  <div class="ed-shell">
    <header class="ed-top">
      <div>
        <h1>${escapeHtml(place.name)}</h1>
        <div class="admin-breadcrumb small muted">
          <a href="/admin/places">Places</a> · ${escapeHtml(place.city || "—")}, ${escapeHtml(place.country || "—")} · #${place.id}
          · ${place.isVisible ? "visible" : "hidden"}
        </div>
      </div>
      <div class="ed-top__actions">
        <form method="post" action="/admin/places/${place.id}/toggle-visible"><button class="btn" type="submit">${place.isVisible ? "Hide" : "Show"}</button></form>
        <a class="btn" href="/place/${place.id}${place.slug ? '/' + place.slug : ''}" target="_blank" rel="noopener">View ↗</a>
      </div>
    </header>

    <nav class="ed-tabs">
      <button type="button" class="ed-tab is-active" data-tab="overview">Overview</button>
      <button type="button" class="ed-tab" data-tab="photos">Photos (${photos.length})</button>
      <button type="button" class="ed-tab" data-tab="reviews">Reviews (${googleReviews.length + taReviews.length})</button>
      <button type="button" class="ed-tab" data-tab="seo">SEO</button>
      <button type="button" class="ed-tab" data-tab="data">Data</button>
    </nav>

    <form method="post" action="/admin/places/${place.id}" class="admin-form ed-form">
      <div class="ed-panel is-active" data-panel="overview">
        <section class="admin-section">
          <h2 class="admin-section__title">Identity</h2>
          <div class="field"><label class="field__label" for="f-name">Name</label><input id="f-name" name="name" value="${escapeAttr(place.name || "")}" required /></div>
          <div class="field"><label class="field__label" for="f-slug">Slug</label><input id="f-slug" name="slug" value="${escapeAttr(place.slug || "")}" placeholder="auto-generated if blank" /></div>
          <label class="checkbox"><input type="checkbox" name="isVisible" value="1" ${place.isVisible ? "checked" : ""} /> <span>Visible on the public site</span></label>
        </section>

        <section class="admin-section">
          <h2 class="admin-section__title">Location</h2>
          <div class="field"><label class="field__label" for="f-addr">Address</label><input id="f-addr" name="addressLine" value="${escapeAttr(place.addressLine || "")}" /></div>
          <div class="field-grid" style="grid-template-columns: 2fr 1fr 1fr;">
            <div class="field"><label class="field__label" for="f-city">City</label><input id="f-city" name="city" value="${escapeAttr(place.city || "")}" required /></div>
            <div class="field"><label class="field__label" for="f-region">Region</label><input id="f-region" name="region" value="${escapeAttr(place.region || "")}" /></div>
            <div class="field"><label class="field__label" for="f-postal">Postal</label><input id="f-postal" name="postalCode" value="${escapeAttr(place.postalCode || "")}" /></div>
          </div>
          <div class="field-grid" style="grid-template-columns: 1fr 1fr 1fr;">
            <div class="field"><label class="field__label" for="f-country">Country</label><input id="f-country" name="country" value="${escapeAttr(place.country || "")}" required /></div>
            <div class="field"><label class="field__label" for="f-lat">Latitude</label><input id="f-lat" name="lat" value="${escapeAttr(place.lat != null ? String(place.lat) : "")}" /></div>
            <div class="field"><label class="field__label" for="f-lng">Longitude</label><input id="f-lng" name="lng" value="${escapeAttr(place.lng != null ? String(place.lng) : "")}" /></div>
          </div>
          ${place.lat != null && place.lng != null ? `<a class="small" href="https://www.google.com/maps/search/?api=1&query=${place.lat},${place.lng}" target="_blank" rel="noopener">Check ${place.lat}, ${place.lng} on Google Maps ↗</a>` : ""}
        </section>

        <section class="admin-section">
          <h2 class="admin-section__title">Contact &amp; links</h2>
          <div class="field"><label class="field__label" for="f-web">Website</label><input id="f-web" name="websiteUrl" type="url" value="${escapeAttr(place.websiteUrl || "")}" placeholder="https://..." /></div>
          <div class="field"><label class="field__label" for="f-ig">Instagram</label><input id="f-ig" name="instagramUrl" type="url" value="${escapeAttr(place.instagramUrl || "")}" /></div>
          <div class="field"><label class="field__label" for="f-gmaps">Google Maps</label><input id="f-gmaps" name="googleMapsUrl" type="url" value="${escapeAttr(place.googleMapsUrl || "")}" /></div>
          <div class="field"><label class="field__label" for="f-ta">TripAdvisor URL</label><input id="f-ta" name="tripadvisorUrl" type="url" value="${escapeAttr(place.tripadvisorUrl || "")}" placeholder="https://www.tripadvisor.com/Restaurant_Review-..." /><span class="field__hint">Paste the correct page if TripAdvisor enrichment can't find this place — opm-runner will scrape it directly.</span></div>
          <div class="field"><label class="field__label" for="f-phone">Phone</label><input id="f-phone" name="phone" value="${escapeAttr(place.phone || "")}" /></div>
        </section>

        <section class="admin-section">
          <h2 class="admin-section__title">Service</h2>
          <div class="field-grid" style="grid-template-columns: 1fr 2fr;">
            <div class="field"><label class="field__label" for="f-price">Price level</label><input id="f-price" name="priceLevel" type="number" min="0" max="4" step="1" value="${escapeAttr(String(place.priceLevel ?? 2))}" /></div>
            <div class="field"><span class="field__label">Service options</span>
              <div class="checkbox-row">
                <label class="checkbox"><input type="checkbox" name="dineIn" value="1" ${place.dineIn ? "checked" : ""} /> <span>Dine-in</span></label>
                <label class="checkbox"><input type="checkbox" name="takeaway" value="1" ${place.takeaway ? "checked" : ""} /> <span>Takeaway</span></label>
                <label class="checkbox"><input type="checkbox" name="delivery" value="1" ${place.delivery ? "checked" : ""} /> <span>Delivery</span></label>
                <label class="checkbox"><input type="checkbox" name="reservations" value="1" ${place.reservations ? "checked" : ""} /> <span>Reservations</span></label>
                <label class="checkbox"><input type="checkbox" name="outdoorSeating" value="1" ${place.outdoorSeating ? "checked" : ""} /> <span>Outdoor</span></label>
              </div>
            </div>
          </div>
          <div class="field"><label class="field__label" for="f-hours">Opening hours</label><textarea id="f-hours" name="openingHours" rows="2">${escapeHtml(place.openingHours || "")}</textarea></div>
        </section>

        <section class="admin-section">
          <h2 class="admin-section__title">Pizza styles</h2>
          <div class="style-chips">
            ${allStyles.map((st) => `<label class="checkbox"><input type="checkbox" name="styleIds" value="${st.id}" ${selectedStyleIds.has(st.id) ? "checked" : ""} /> <span>${escapeHtml(st.name)}</span></label>`).join("")}
          </div>
        </section>

        <section class="admin-section">
          <h2 class="admin-section__title">Hero &amp; description</h2>
          <div class="field"><label class="field__label" for="f-hero">Hero image URL</label><input id="f-hero" name="heroImageUrl" value="${escapeAttr(place.heroImageUrl || "")}" placeholder="set via the Photos tab" /></div>
          <div class="field"><span class="field__label">Description</span><div id="editor"></div><input type="hidden" name="descriptionHtml" id="descriptionHtml" /></div>
        </section>
      </div>

      <div class="ed-panel" data-panel="seo">
        <section class="admin-section">
          <h2 class="admin-section__title">SEO</h2>
          <div class="field"><label class="field__label" for="f-seo-title">Title</label><input id="f-seo-title" name="seoTitle" value="${escapeAttr(place.seoTitle || "")}" /></div>
          <div class="field"><label class="field__label" for="f-seo-desc">Description</label><textarea id="f-seo-desc" name="seoDescription" rows="2" maxlength="200">${escapeHtml(place.seoDescription || "")}</textarea><span class="field__hint">Max 200 characters.</span></div>
        </section>
        <section class="admin-section">
          <h2 class="admin-section__title">OpenPizzaMap rating</h2>
          <div class="field"><label class="field__label" for="f-opm">Composite score (1.0–10.0)</label><input id="f-opm" name="opmRating" type="number" min="1" max="10" step="0.1" value="${escapeAttr(place.opmRating != null ? String(place.opmRating) : "")}" /><span class="field__hint">Manual override. Blank hides the badge until auto-compute runs.</span></div>
        </section>
      </div>

      <div class="ed-actions-bar">
        <a class="btn" href="/admin/places">← Back</a>
        <button type="submit" class="btn primary">Save changes</button>
      </div>
    </form>

    <div class="ed-panel" data-panel="photos">
      <section class="admin-section">
        <h2 class="admin-section__title">Photos (${photos.length})</h2>
        <p class="field__hint">Reorder, hide, or pick the hero. Hidden photos survive re-scrapes. Position 1 is the gallery default.</p>
        ${photos.length === 0 ? `<p class="field__hint">No gallery photos scraped yet.</p>` : `
        <div class="admin-photo-grid">
          ${photos.map((img, i) => `
            <div class="admin-photo${img.isHidden ? " is-hidden" : ""}${img.isHero ? " is-hero" : ""}">
              <img class="admin-photo__img" src="${escapeAttr(img.thumb)}" alt="" loading="lazy" onerror="this.style.opacity=0.2;this.alt='missing file';" />
              <div class="admin-photo__meta">#${img.position} · ${escapeHtml(img.source || "?")}${img.isHero ? " · ★ hero" : ""}${img.isHidden ? " · hidden" : ""}</div>
              <div class="admin-photo__actions">
                <form method="post" action="/admin/places/${place.id}/photos/${img.id}/move?dir=up"><button type="submit" title="Move up" ${i === 0 ? "disabled" : ""}>↑</button></form>
                <form method="post" action="/admin/places/${place.id}/photos/${img.id}/move?dir=down"><button type="submit" title="Move down" ${i === photos.length - 1 ? "disabled" : ""}>↓</button></form>
                <form method="post" action="/admin/places/${place.id}/photos/${img.id}/toggle-hidden"><button type="submit">${img.isHidden ? "Show" : "Hide"}</button></form>
                <form method="post" action="/admin/places/${place.id}/photos/${img.id}/set-hero"><button type="submit" ${img.isHero ? "disabled" : ""}>Set hero</button></form>
              </div>
            </div>`).join("")}
        </div>`}
      </section>
    </div>

    <div class="ed-panel" data-panel="reviews">
      <section class="admin-section">
        <h2 class="admin-section__title">Google reviews (${googleReviews.length})</h2>
        <p class="field__hint">Reorder or hide individual reviews. Hidden reviews never show on the public page and survive re-scrapes.</p>
        ${googleReviews.length ? googleReviews.map(reviewRow).join("") : `<p class="field__hint">No Google reviews scraped yet.</p>`}
      </section>
      ${taReviews.length ? `
      <section class="admin-section">
        <h2 class="admin-section__title">TripAdvisor reviews (${taReviews.length})</h2>
        ${taReviews.map(reviewRow).join("")}
      </section>` : ""}
    </div>

    <div class="ed-panel" data-panel="data">
      <section class="admin-section">
        <h2 class="admin-section__title">Identifiers &amp; sources</h2>
        <table class="ed-data">
          <tr><th>Place ID</th><td>${place.id}</td></tr>
          <tr><th>Google placeId</th><td class="ed-mono">${place.googlePlaceId ? escapeHtml(place.googlePlaceId) + (ftid ? ' <span class="ed-tag">FTID</span>' : "") : "—"}</td></tr>
          <tr><th>Google Maps URL</th><td>${place.googleMapsUrl ? `<a href="${escapeAttr(place.googleMapsUrl)}" target="_blank" rel="noopener">open ↗</a>` : "—"}</td></tr>
          <tr><th>Google rating</th><td>${place.googleRating != null ? `★ ${place.googleRating} · ${place.googleReviewCount ?? "—"} reviews` : "—"}</td></tr>
          <tr><th>TripAdvisor</th><td>${place.tripadvisorRating != null ? `★ ${place.tripadvisorRating} · ${place.tripadvisorReviewCount ?? "—"} reviews` : "—"}${place.tripadvisorUrl ? ` · <a href="${escapeAttr(place.tripadvisorUrl)}" target="_blank" rel="noopener">open ↗</a>` : ""}</td></tr>
          <tr><th>TripAdvisor locationId</th><td>${place.tripadvisorLocationId != null ? (place.tripadvisorLocationId === -1 ? '<span class="ed-tag ed-tag--hidden">not found (-1)</span>' : place.tripadvisorLocationId) : "—"}</td></tr>
        </table>
      </section>
      <section class="admin-section">
        <h2 class="admin-section__title">Enrichment timestamps</h2>
        <table class="ed-data">
          <tr><th>Enriched</th><td>${fmtDate(place.enrichedAt)}</td></tr>
          <tr><th>Google ratings scraped</th><td>${fmtDate(place.googleRatingsScrapedAt)}</td></tr>
          <tr><th>Google reviews fetched</th><td>${fmtDate(place.googleReviewsFetchedAt)}</td></tr>
          <tr><th>Gallery scraped</th><td>${fmtDate(place.galleryLastScrapedAt)}</td></tr>
          <tr><th>TripAdvisor ratings scraped</th><td>${fmtDate(place.tripadvisorRatingsScrapedAt)}</td></tr>
          <tr><th>Created</th><td>${fmtDate(place.createdAt)}</td></tr>
          <tr><th>Updated</th><td>${fmtDate(place.updatedAt)}</td></tr>
        </table>
      </section>
      <section class="admin-section ed-danger">
        <h2 class="admin-section__title">Danger zone</h2>
        <p class="field__hint">Permanently delete this place and all its photos, reviews, visits and favorites. Type the place ID (<strong>${place.id}</strong>) to confirm.</p>
        <form method="post" action="/admin/places/${place.id}/delete" class="ed-danger__form" onsubmit="return confirm('Delete ${escapeAttr(place.name)} permanently?');">
          <input name="confirm" placeholder="${place.id}" autocomplete="off" />
          <button type="submit" class="btn btn--danger">Delete place</button>
        </form>
      </section>
    </div>
  </div>

  <style>
    .ed-shell { max-width: 920px; }
    .ed-top { display:flex; justify-content:space-between; align-items:flex-start; gap:16px; flex-wrap:wrap; }
    .ed-top__actions { display:flex; gap:8px; }
    .ed-top__actions form { margin:0; }
    .ed-tabs { display:flex; gap:4px; flex-wrap:wrap; border-bottom:1px solid #ddd; margin:14px 0 18px; }
    .ed-tab { border:none; background:none; padding:10px 16px; font-size:14px; font-weight:600; color:#888; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-1px; }
    .ed-tab.is-active { color:#c0392b; border-bottom-color:#c0392b; }
    .ed-panel { display:none; }
    .ed-panel.is-active { display:block; }
    .ed-actions-bar { display:flex; justify-content:flex-end; gap:10px; position:sticky; bottom:0; background:linear-gradient(transparent, #faf8f4 30%); padding:14px 0; }
    .ed-rev { display:flex; gap:12px; padding:10px 0; border-bottom:1px solid #ececec; }
    .ed-rev.is-hidden { opacity:.5; }
    .ed-rev__main { flex:1; min-width:0; }
    .ed-rev__head { display:flex; gap:8px; align-items:baseline; flex-wrap:wrap; }
    .ed-rev__stars { color:#c0392b; font-weight:600; font-size:13px; }
    .ed-rev__text { margin-top:3px; color:#444; }
    .ed-rev__actions { display:flex; gap:4px; align-items:flex-start; }
    .ed-rev__actions form { margin:0; }
    .ed-rev__actions button { font-size:12px; padding:4px 8px; cursor:pointer; border:1px solid #ccc; border-radius:5px; background:#fff; }
    .ed-tag { font-size:10px; text-transform:uppercase; letter-spacing:.04em; background:#eee; color:#777; padding:1px 6px; border-radius:4px; }
    .ed-tag--hidden { background:#fbeaea; color:#c0392b; }
    .ed-data { width:100%; border-collapse:collapse; }
    .ed-data th { text-align:left; font-weight:600; color:#777; padding:5px 10px 5px 0; width:200px; vertical-align:top; font-size:13px; }
    .ed-data td { padding:5px 0; font-size:13px; }
    .ed-mono { font-family:ui-monospace,Menlo,Consolas,monospace; font-size:12px; word-break:break-all; }
    .ed-danger { border:1px solid #f0c9c9; border-radius:8px; background:#fdf5f5; }
    .ed-danger__form { display:flex; gap:8px; align-items:center; }
    .ed-danger__form input { max-width:120px; }
    .btn--danger { background:#c0392b; color:#fff; border-color:#c0392b; }
    .admin-photo-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(140px,1fr)); gap:12px; }
    .admin-photo { border:1px solid #e2e2e2; border-radius:8px; padding:8px; background:#fff; }
    .admin-photo.is-hidden { opacity:.5; }
    .admin-photo.is-hero { border-color:#e0a92b; }
    .admin-photo__img { width:100%; height:110px; object-fit:cover; border-radius:6px; display:block; background:#f0f0f0; }
    .admin-photo__meta { font-size:12px; color:#888; margin:6px 0; }
    .admin-photo__actions { display:flex; flex-wrap:wrap; gap:4px; }
    .admin-photo__actions form { margin:0; }
    .admin-photo__actions button { font-size:12px; padding:4px 8px; cursor:pointer; border:1px solid #ccc; border-radius:5px; background:#fff; }
    .admin-photo__actions button:disabled { opacity:.35; cursor:default; }
  </style>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      // Tabs
      var tabs = document.querySelectorAll(".ed-tab");
      var panels = document.querySelectorAll(".ed-panel");
      function show(name) {
        tabs.forEach(function (t) { t.classList.toggle("is-active", t.dataset.tab === name); });
        panels.forEach(function (p) { p.classList.toggle("is-active", p.dataset.panel === name); });
      }
      tabs.forEach(function (t) { t.addEventListener("click", function () { show(t.dataset.tab); }); });

      // Quill editor
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("descriptionHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (editorEl && input && form) {
        var quill = new Quill(editorEl, { theme: "snow", modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] } });
        quill.root.innerHTML = ${JSON.stringify(place.descriptionHtml || "")};
        form.addEventListener("submit", function () { input.value = quill.root.innerHTML || ""; });
      }
    })();
  </script>
` }) %>
