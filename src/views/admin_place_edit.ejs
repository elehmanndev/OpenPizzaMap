<%- include("layout", { title: `Admin · Place · ${place.name}`, user, leaflet: false, bodyClass: "admin-page", body: String.raw`
  <div class="admin-shell">
    <h1>${escapeHtml(place.name)}</h1>
    <div class="admin-breadcrumb">
      <a href="/admin/places">Places</a> · ${escapeHtml(place.city)}, ${escapeHtml(place.country)} · #${place.id}${place.enrichedAt ? ` · enriched ${new Date(place.enrichedAt).toISOString().slice(0,10)}` : ""}
    </div>

    <form method="post" action="/admin/places/${place.id}" class="admin-form">

      <section class="admin-section">
        <h2 class="admin-section__title">Identity</h2>
        <div class="field">
          <label class="field__label" for="f-name">Name</label>
          <input id="f-name" name="name" value="${escapeAttr(place.name || "")}" required />
        </div>
        <div class="field">
          <label class="field__label" for="f-slug">Slug</label>
          <input id="f-slug" name="slug" value="${escapeAttr(place.slug || "")}" placeholder="il-figlio-di-emiliano-sabadell" />
          <span class="field__hint">URL fragment. Leave blank to auto-generate.</span>
        </div>
        <label class="checkbox">
          <input type="checkbox" name="isVisible" value="1" ${place.isVisible ? "checked" : ""} />
          <span>Visible on the public site</span>
        </label>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">Location</h2>
        <div class="field">
          <label class="field__label" for="f-addr">Address</label>
          <input id="f-addr" name="addressLine" value="${escapeAttr(place.addressLine || "")}" />
        </div>
        <div class="field-grid" style="grid-template-columns: 2fr 1fr 1fr;">
          <div class="field">
            <label class="field__label" for="f-city">City</label>
            <input id="f-city" name="city" value="${escapeAttr(place.city || "")}" required />
          </div>
          <div class="field">
            <label class="field__label" for="f-region">Region</label>
            <input id="f-region" name="region" value="${escapeAttr(place.region || "")}" />
          </div>
          <div class="field">
            <label class="field__label" for="f-postal">Postal</label>
            <input id="f-postal" name="postalCode" value="${escapeAttr(place.postalCode || "")}" />
          </div>
        </div>
        <div class="field-grid" style="grid-template-columns: 1fr 1fr 1fr;">
          <div class="field">
            <label class="field__label" for="f-country">Country</label>
            <input id="f-country" name="country" value="${escapeAttr(place.country || "")}" required />
          </div>
          <div class="field">
            <label class="field__label" for="f-lat">Latitude</label>
            <input id="f-lat" name="lat" value="${escapeAttr(place.lat != null ? String(place.lat) : "")}" placeholder="41.5482" />
          </div>
          <div class="field">
            <label class="field__label" for="f-lng">Longitude</label>
            <input id="f-lng" name="lng" value="${escapeAttr(place.lng != null ? String(place.lng) : "")}" placeholder="2.1075" />
          </div>
        </div>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">Contact &amp; links</h2>
        <div class="field">
          <label class="field__label" for="f-web">Website</label>
          <input id="f-web" name="websiteUrl" type="url" value="${escapeAttr(place.websiteUrl || "")}" placeholder="https://..." />
        </div>
        <div class="field">
          <label class="field__label" for="f-ig">Instagram</label>
          <input id="f-ig" name="instagramUrl" type="url" value="${escapeAttr(place.instagramUrl || "")}" placeholder="https://instagram.com/..." />
        </div>
        <div class="field">
          <label class="field__label" for="f-gmaps">Google Maps</label>
          <input id="f-gmaps" name="googleMapsUrl" type="url" value="${escapeAttr(place.googleMapsUrl || "")}" placeholder="https://maps.google.com/..." />
        </div>
        <div class="field">
          <label class="field__label" for="f-phone">Phone</label>
          <input id="f-phone" name="phone" value="${escapeAttr(place.phone || "")}" placeholder="+39 ..." />
        </div>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">Service</h2>
        <div class="field-grid" style="grid-template-columns: 1fr 2fr;">
          <div class="field">
            <label class="field__label" for="f-price">Price level</label>
            <input id="f-price" name="priceLevel" type="number" min="0" max="4" step="1" value="${escapeAttr(String(place.priceLevel ?? 2))}" />
            <span class="field__hint">0 (free) – 4 (expensive)</span>
          </div>
          <div class="field">
            <span class="field__label">Service options</span>
            <div class="checkbox-row">
              <label class="checkbox"><input type="checkbox" name="dineIn" value="1" ${place.dineIn ? "checked" : ""} /> <span>Dine-in</span></label>
              <label class="checkbox"><input type="checkbox" name="takeaway" value="1" ${place.takeaway ? "checked" : ""} /> <span>Takeaway</span></label>
              <label class="checkbox"><input type="checkbox" name="delivery" value="1" ${place.delivery ? "checked" : ""} /> <span>Delivery</span></label>
              <label class="checkbox"><input type="checkbox" name="reservations" value="1" ${place.reservations ? "checked" : ""} /> <span>Reservations</span></label>
              <label class="checkbox"><input type="checkbox" name="outdoorSeating" value="1" ${place.outdoorSeating ? "checked" : ""} /> <span>Outdoor seating</span></label>
            </div>
          </div>
        </div>
        <div class="field">
          <label class="field__label" for="f-hours">Opening hours</label>
          <textarea id="f-hours" name="openingHours" rows="2">${escapeHtml(place.openingHours || "")}</textarea>
          <span class="field__hint">schema.org weekly format, e.g. <code>Mo-Sa 12:00-23:00</code></span>
        </div>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">Pizza styles</h2>
        <div class="style-chips">
          ${allStyles.map((st) => `
            <label class="checkbox">
              <input type="checkbox" name="styleIds" value="${st.id}" ${selectedStyleIds.has(st.id) ? "checked" : ""} />
              <span>${escapeHtml(st.name)}</span>
            </label>
          `).join("")}
        </div>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">Hero &amp; description</h2>
        <div class="field">
          <label class="field__label" for="f-hero">Hero image URL</label>
          <input id="f-hero" name="heroImageUrl" value="${escapeAttr(place.heroImageUrl || "")}" placeholder="/uploads/places/123.jpg" />
        </div>
        <div class="field">
          <span class="field__label">Description</span>
          <div id="editor"></div>
          <input type="hidden" name="descriptionHtml" id="descriptionHtml" />
        </div>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">SEO</h2>
        <div class="field">
          <label class="field__label" for="f-seo-title">Title</label>
          <input id="f-seo-title" name="seoTitle" value="${escapeAttr(place.seoTitle || "")}" />
        </div>
        <div class="field">
          <label class="field__label" for="f-seo-desc">Description</label>
          <textarea id="f-seo-desc" name="seoDescription" rows="2" maxlength="200">${escapeHtml(place.seoDescription || "")}</textarea>
          <span class="field__hint">Max 200 characters.</span>
        </div>
      </section>

      <section class="admin-section">
        <h2 class="admin-section__title">OpenPizzaMap rating</h2>
        <div class="field">
          <label class="field__label" for="f-opm">Composite score (1.0–10.0)</label>
          <input id="f-opm" name="opmRating" type="number" min="1" max="10" step="0.1" value="${escapeAttr(place.opmRating != null ? String(place.opmRating) : "")}" />
          <span class="field__hint">Manual override. Leave blank to hide the badge until the auto-compute job runs.</span>
        </div>
      </section>

      ${(place.tripadvisorLocationId || place.googleRating != null || place.yelpRating != null) ? `
      <section class="admin-section admin-readonly">
        <h2 class="admin-section__title">External ratings (read-only)</h2>
        ${place.tripadvisorLocationId ? `
          <p>TripAdvisor · ★ ${place.tripadvisorRating ?? "—"} · ${place.tripadvisorReviewCount ?? "—"} reviews${place.tripadvisorRanking ? ` · ${escapeHtml(place.tripadvisorRanking)}` : ""}</p>
          ${place.tripadvisorUrl ? `<a href="${escapeAttr(place.tripadvisorUrl)}" target="_blank" rel="noopener">Open on TripAdvisor →</a>` : ""}
        ` : ""}
        ${place.googleRating != null ? `
          <p>Google · ★ ${place.googleRating} · ${place.googleReviewCount ?? "—"} reviews</p>
          ${place.googleUrl ? `<a href="${escapeAttr(place.googleUrl)}" target="_blank" rel="noopener">Open on Google →</a>` : ""}
        ` : ""}
        ${place.yelpRating != null ? `
          <p>Yelp · ★ ${place.yelpRating} · ${place.yelpReviewCount ?? "—"} reviews</p>
          ${place.yelpUrl ? `<a href="${escapeAttr(place.yelpUrl)}" target="_blank" rel="noopener">Open on Yelp →</a>` : ""}
        ` : ""}
      </section>
      ` : ""}

      <div class="admin-actions">
        <a class="btn" href="/admin/places">← Back</a>
        <a class="btn" href="/place/${place.id}${place.slug ? '/' + place.slug : ''}" target="_blank" rel="noopener">View</a>
        <button type="submit" class="btn primary">Save changes</button>
      </div>
    </form>

    <section class="admin-section">
      <h2 class="admin-section__title">Photos (${photos.length})</h2>
      <p class="field__hint">Reorder, hide, or pick the hero. Hidden photos survive re-scrapes. Position 1 is the gallery default.</p>
      ${photos.length === 0 ? `<p class="field__hint">No gallery photos scraped yet.</p>` : `
      <div class="admin-photo-grid">
        ${photos.map((img, i) => `
          <div class="admin-photo${img.isHidden ? " is-hidden" : ""}${img.isHero ? " is-hero" : ""}">
            <img class="admin-photo__img" src="${escapeAttr(img.thumb)}" alt="" loading="lazy"
                 onerror="this.style.opacity=0.2;this.alt='missing file';" />
            <div class="admin-photo__meta">#${img.position} · ${escapeHtml(img.source || "?")}${img.isHero ? " · ★ hero" : ""}${img.isHidden ? " · hidden" : ""}</div>
            <div class="admin-photo__actions">
              <form method="post" action="/admin/places/${place.id}/photos/${img.id}/move?dir=up"><button type="submit" title="Move up" ${i === 0 ? "disabled" : ""}>↑</button></form>
              <form method="post" action="/admin/places/${place.id}/photos/${img.id}/move?dir=down"><button type="submit" title="Move down" ${i === photos.length - 1 ? "disabled" : ""}>↓</button></form>
              <form method="post" action="/admin/places/${place.id}/photos/${img.id}/toggle-hidden"><button type="submit">${img.isHidden ? "Show" : "Hide"}</button></form>
              <form method="post" action="/admin/places/${place.id}/photos/${img.id}/set-hero"><button type="submit" ${img.isHero ? "disabled" : ""}>Set hero</button></form>
            </div>
          </div>
        `).join("")}
      </div>
      `}
    </section>
  </div>

  <style>
    .admin-photo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
    .admin-photo { border: 1px solid #2a2a2a; border-radius: 8px; padding: 8px; background: #1b1b1b; }
    .admin-photo.is-hidden { opacity: 0.5; }
    .admin-photo.is-hero { border-color: #e0a92b; }
    .admin-photo__img { width: 100%; height: 110px; object-fit: cover; border-radius: 6px; display: block; background: #111; }
    .admin-photo__meta { font-size: 12px; color: #aaa; margin: 6px 0; }
    .admin-photo__actions { display: flex; flex-wrap: wrap; gap: 4px; }
    .admin-photo__actions form { margin: 0; }
    .admin-photo__actions button { font-size: 12px; padding: 4px 8px; cursor: pointer; border: 1px solid #3a3a3a; border-radius: 5px; background: #262626; color: #eee; }
    .admin-photo__actions button:disabled { opacity: 0.35; cursor: default; }
  </style>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("descriptionHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (!editorEl || !input || !form) return;

      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(place.descriptionHtml || "")};

      form.addEventListener("submit", function () {
        input.value = quill.root.innerHTML || "";
      });
    })();
  </script>
` }) %>
