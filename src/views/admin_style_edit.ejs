<%- include("layout", { title: style ? `Admin · Style · ${style.slug}` : "Admin · New Style", user, leaflet: false, body: String.raw`
  <h1>${style ? "Edit style: " + escapeHtml(style.name) : "New style"}</h1>

  <form method="post" action="${style ? "/admin/styles/" + style.id : "/admin/styles"}" class="card" style="display:grid; gap:14px;">

    <div class="row" style="gap:12px;">
      <label style="flex:1; min-width:160px;">
        <div class="small">Slug <span class="muted">(URL-safe, unique)</span></div>
        <input name="slug" value="${escapeAttr(style ? style.slug : "")}" placeholder="neapolitan" required maxlength="40" ${style ? "" : ""} />
      </label>
      <label style="flex:2; min-width:200px;">
        <div class="small">Name</div>
        <input name="name" value="${escapeAttr(style ? style.name : "")}" placeholder="Neapolitan" required maxlength="80" />
      </label>
    </div>

    <div class="row" style="gap:12px;">
      <label style="flex:1; min-width:160px;">
        <div class="small">Short label <span class="muted">(badge text)</span></div>
        <input name="shortLabel" value="${escapeAttr(style ? (style.shortLabel || "") : "")}" placeholder="Neapolitan" maxlength="40" />
      </label>
      <label style="flex:1; min-width:100px;">
        <div class="small">Sort order</div>
        <input name="sortOrder" type="number" value="${style ? style.sortOrder : 0}" min="0" max="999" />
      </label>
    </div>

    <label>
      <div class="small">Hero image URL</div>
      <input name="heroImageUrl" value="${escapeAttr(style ? (style.heroImageUrl || "") : "")}" placeholder="https://..." maxlength="500" />
    </label>

    <div>
      <div class="small" style="margin-bottom:4px;">Intro (rich text)</div>
      <div id="editor" style="background: var(--c-surface);"></div>
      <input type="hidden" name="introHtml" id="introHtml" />
    </div>

    <label>
      <div class="small">SEO title</div>
      <input name="seoTitle" value="${escapeAttr(style ? (style.seoTitle || "") : "")}" placeholder="Best Neapolitan Pizza" maxlength="191" />
    </label>

    <label>
      <div class="small">SEO description <span class="muted">(max 200)</span></div>
      <input name="seoDescription" value="${escapeAttr(style ? (style.seoDescription || "") : "")}" placeholder="Explore the world's best..." maxlength="200" />
    </label>

    <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
      <input type="checkbox" name="isVisible" value="1" ${style && style.isVisible ? "checked" : ""} />
      <span>Visible on public pages</span>
    </label>

    <div class="row" style="gap:10px; margin-top:4px;">
      <button type="submit" class="btn primary">${style ? "Save changes" : "Create style"}</button>
      <a class="btn" href="/admin/styles">Back</a>
    </div>
  </form>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var input = document.getElementById("introHtml");
      var form = editorEl ? editorEl.closest("form") : null;
      if (!editorEl || !input || !form) return;
      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(style ? (style.introHtml || "") : "")};
      form.addEventListener("submit", function () { input.value = quill.root.innerHTML || ""; });
    })();
  </script>
` }) %>
