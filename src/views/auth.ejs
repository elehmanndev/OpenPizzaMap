<%- include("layout", { title: "Sign in", user, leaflet: false, bodyClass: "auth-page", body: String.raw`
<section class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="auth-logo">OPM</span>
      <div>
        <span class="auth-brand-name">OpenPizzaMap</span>
        <span class="auth-brand-tag">Sign in to track and share your pizza spots</span>
      </div>
    </div>
    <h1 class="auth-title">Welcome to OpenPizzaMap</h1>
    <p class="auth-subtitle">One-click sign in with your Google account. No passwords, no email back-and-forth.</p>
    ${googleAuthEnabled ? String.raw`
      <a class="auth-social" href="/api/auth/google">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.2-.9 2.1-1.9 2.8v2.3h3.1c1.8-1.6 2.9-4 2.9-6.9 0-.7-.1-1.4-.2-2.1H12z"/>
          <path fill="#34A853" d="M12 22c2.6 0 4.8-.9 6.4-2.5l-3.1-2.3c-.9.6-2 .9-3.3.9-2.5 0-4.6-1.7-5.4-4.1H3.4v2.6C5 19.9 8.2 22 12 22z"/>
          <path fill="#4A90E2" d="M6.6 13.9c-.2-.6-.3-1.3-.3-1.9s.1-1.3.3-1.9V7.5H3.4C2.8 8.8 2.4 10.4 2.4 12s.4 3.2 1 4.5l3.2-2.6z"/>
          <path fill="#FBBC05" d="M12 5.8c1.4 0 2.6.5 3.6 1.4l2.7-2.7C16.8 2.8 14.6 2 12 2 8.2 2 5 4.1 3.4 7.5l3.2 2.6C7.4 7.5 9.5 5.8 12 5.8z"/>
        </svg>
        Continue with Google
      </a>
    ` : String.raw`
      <p class="auth-msg" role="alert">Google sign-in is currently unavailable. Try again later.</p>
    `}
  </div>
</section>
` }) %>
