<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpenPizzaMap — Community pizza map</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= asset('/public/css/styles.css') %>" />
</head>
<body class="opm-home">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">

  <header class="opm-home-header">
    <a href="/" class="opm-home-brand">OpenPizzaMap</a>
    <nav class="opm-home-nav">
      <% if (user) { %>
        <a href="/me" class="opm-home-userchip" aria-label="My profile">
          <% if (user.avatarUrl) { %>
            <img src="<%= user.avatarUrl %>" alt="" referrerpolicy="no-referrer" />
          <% } else { %>
            <span class="opm-home-userchip-fallback">
              <%= (user.displayName || user.email || "?")[0].toUpperCase() %>
            </span>
          <% } %>
        </a>
      <% } else { %>
        <a href="/map">Map</a>
        <a href="/auth" class="opm-home-signin">Sign in</a>
      <% } %>
      <button class="opm-home-menu" id="sidebar-open" aria-label="Open menu">
        <span class="material-symbols-rounded" aria-hidden="true">menu</span>
      </button>
    </nav>
  </header>

  <!-- Slide-in sidebar (same markup as layout.ejs so the styles in
       styles.css apply unchanged). The hamburger button above opens it. -->
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>
  <nav class="sidebar" id="sidebar" aria-label="Navigation">
    <div class="sidebar-head">
      <% if (user) { %>
        <div class="sidebar-user">
          <div class="sidebar-avatar">
            <% if (user.avatarUrl) { %>
              <img src="<%= user.avatarUrl %>" alt="" referrerpolicy="no-referrer" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />
            <% } else { %>
              <%= (user.displayName || user.email || "?")[0].toUpperCase() %>
            <% } %>
          </div>
          <div class="sidebar-user-info">
            <div class="sidebar-user-name"><%= user.displayName || user.username %></div>
            <% if (user.username) { %><div class="sidebar-user-handle">@<%= user.username %></div><% } %>
          </div>
        </div>
      <% } else { %>
        <div class="sidebar-brand">OpenPizzaMap</div>
      <% } %>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close menu">
        <span class="material-symbols-rounded">close</span>
      </button>
    </div>

    <div class="sidebar-links">
      <a href="/map" class="sidebar-link">
        <span class="material-symbols-rounded">map</span>
        Map
      </a>
      <% if (user) { %>
        <a href="/add-your-spot" class="sidebar-link">
          <span class="material-symbols-rounded">add_location_alt</span>
          Add your spot
        </a>
        <a href="/me" class="sidebar-link">
          <span class="material-symbols-rounded">person</span>
          My profile
        </a>
        <a href="/settings" class="sidebar-link">
          <span class="material-symbols-rounded">settings</span>
          Settings
        </a>
        <% if (user.role === "admin") { %>
          <div class="sidebar-section-label">Admin</div>
          <a href="/admin/places" class="sidebar-link">
            <span class="material-symbols-rounded">storefront</span>
            Places
          </a>
          <a href="/admin/styles" class="sidebar-link">
            <span class="material-symbols-rounded">style</span>
            Styles
          </a>
          <a href="/admin/submissions" class="sidebar-link">
            <span class="material-symbols-rounded">inbox</span>
            Submissions
          </a>
          <a href="/admin/merge" class="sidebar-link">
            <span class="material-symbols-rounded">merge</span>
            Merge duplicates
          </a>
        <% } %>
      <% } %>
    </div>

    <div class="sidebar-foot">
      <% if (user) { %>
        <form method="post" action="/logout">
          <button type="submit" class="sidebar-logout">
            <span class="material-symbols-rounded">logout</span>
            Sign out
          </button>
        </form>
      <% } else { %>
        <a href="/auth" class="sidebar-signin">Sign in</a>
      <% } %>
    </div>
  </nav>

  <!-- Hero: bold heading + tagline + search on the left, photo collage on the right (desktop) -->
  <section class="opm-hero">
    <div class="opm-hero-grid">
      <div class="opm-hero-text">
        <div class="opm-hero-badge">
          <span class="opm-hero-badge-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" style="color: var(--c-accent);"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </span>
          <strong><%= counters.places.toLocaleString('en-US') %></strong>
          <span>pizzerias in <%= counters.countries %> countries</span>
        </div>
        <h1>Find pizza<br>worth crossing<br>the street for.</h1>
        <p class="opm-hero-tagline">
          The community-curated pizza map. Real opinions from people who
          actually eat there — not algorithms, not Yelp lectures.
        </p>
        <form action="/map" method="get" class="opm-hero-search">
          <span class="opm-hero-search-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </span>
          <input type="text" name="query" placeholder="Search a city or pizzeria" autocomplete="off" />
          <button type="submit">Search</button>
        </form>
        <a href="/map" class="opm-hero-maplink">Or open the full map &rarr;</a>
      </div>
      <div class="opm-hero-collage" aria-hidden="true">
        <% collage.forEach(function (c, i) { %>
          <div class="opm-hero-collage-tile opm-hero-collage-tile-<%= i %>">
            <img src="<%= c.image %>" alt="" loading="lazy"
                 onerror="this.onerror=null;this.src='<%= c.fallback %>';this.classList.add('opm-hero-collage-fallback');" />
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <%
    function renderRow(opts) {
      return `
      <section class="opm-row">
        <div class="opm-row-head">
          <div>
            <h2>${escapeHtml(opts.title)}</h2>
            <p class="opm-row-sub">${escapeHtml(opts.subtitle || "")}</p>
          </div>
          ${opts.viewAllHref ? `<a class="opm-row-viewall" href="${escapeAttr(opts.viewAllHref)}">View all &rarr;</a>` : ""}
        </div>
        <div class="opm-row-scroll" role="region" aria-label="${escapeAttr(opts.title)}">
          <button class="opm-row-arrow opm-row-arrow-left" aria-label="Scroll left" data-dir="-1">&larr;</button>
          <div class="opm-row-track">
            ${opts.cards.map((c) => `
              <a class="opm-row-card" href="${escapeAttr(c.href)}">
                <img class="opm-row-card-img" src="${escapeAttr(c.image)}" alt="" loading="lazy"
                     onerror="this.onerror=null;this.src='${escapeAttr(c.fallback)}';this.classList.add('opm-row-card-img-fallback');" />
                <div class="opm-row-card-scrim"></div>
                <div class="opm-row-card-title">${escapeHtml(c.title)}${c.subtitle ? `<span class="opm-row-card-sub">, ${escapeHtml(c.subtitle)}</span>` : ""}</div>
              </a>
            `).join("")}
          </div>
          <button class="opm-row-arrow opm-row-arrow-right" aria-label="Scroll right" data-dir="1">&rarr;</button>
        </div>
      </section>`;
    }
  %>

  <main class="opm-home-main">
    <%- renderRow({
      title: "Discover the best pizzerias in your city",
      subtitle: "The cities with the deepest community coverage",
      viewAllHref: "/map",
      cards: cityCards,
    }) %>

    <!-- Map CTA banner — bridges the city row to the curated section -->
    <a href="/map" class="opm-mapcta" aria-label="Explore the full map">
      <div class="opm-mapcta-text">
        <span class="opm-mapcta-eyebrow">The big picture</span>
        <h2>One map, <%= counters.places.toLocaleString('en-US') %> pizzerias.</h2>
        <p>Pan, zoom, filter. The whole community map in one place.</p>
      </div>
      <div class="opm-mapcta-action">
        <span class="opm-mapcta-button">
          Open the map
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
        </span>
      </div>
    </a>

    <!-- Featured Places (curated) with tab filter -->
    <section class="opm-featured">
      <div class="opm-featured-head">
        <span class="opm-featured-eyebrow">CURATED</span>
        <h2>Featured pizzerias</h2>
        <p class="opm-featured-sub">Hand-picked highlights — top-rated, newly added, and crowd favorites.</p>
        <div class="opm-featured-tabs" role="tablist">
          <% const tabs = [
            { id: "top-rated", label: "Top Rated" },
            { id: "newly-added", label: "Newly Added" },
            { id: "most-reviewed", label: "Most Reviewed" },
            { id: "editors-picks", label: "Editor's Picks" },
          ]; %>
          <% tabs.forEach(function (t) { %>
            <a href="?tab=<%= t.id %>#featured"
               class="opm-featured-tab<%= activeTab === t.id ? ' is-active' : '' %>"
               role="tab"><%= t.label %></a>
          <% }) %>
        </div>
      </div>
      <div class="opm-featured-track-wrap" id="featured">
        <div class="opm-featured-track">
          <% featured.forEach(function (p) { %>
            <a class="opm-featured-card" href="<%= escapeAttr(p.href) %>">
              <div class="opm-featured-card-imgwrap">
                <img class="opm-featured-card-img" src="<%= p.image %>" alt="" loading="lazy"
                     onerror="this.onerror=null;this.src='<%= p.fallback %>';this.classList.add('opm-featured-card-img-fallback');" />
                <span class="opm-featured-card-pill"><%= p.categoryLabel %></span>
              </div>
              <div class="opm-featured-card-body">
                <h3><%= p.title %></h3>
                <p class="opm-featured-card-addr">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;flex-shrink:0;" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <%= p.address %>
                </p>
                <div class="opm-featured-card-foot">
                  <span class="opm-featured-card-rating">
                    <% if (p.rating) { %>
                      <span class="opm-star" aria-hidden="true">★</span>
                      <strong><%= p.rating %></strong>
                      <% if (p.reviewCount) { %>
                        <span class="opm-featured-card-revcount">(<%= p.reviewCount.toLocaleString('en-US') %>)</span>
                      <% } %>
                    <% } else { %>
                      <span class="opm-featured-card-revcount">No ratings yet</span>
                    <% } %>
                  </span>
                  <% if (p.priceLevel) { %>
                    <span class="opm-featured-card-price">
                      <%= "$".repeat(Math.max(1, Math.min(4, p.priceLevel))) %>
                    </span>
                  <% } %>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </section>

    <!-- Newsletter banner splits the city row from the style row -->
    <section class="opm-newsletter">
      <div class="opm-newsletter-inner">
        <div class="opm-newsletter-copy">
          <h2>Get the slice, weekly.</h2>
          <p>One pizza email per week. New places, hidden gems, no spam — drop your email and we'll save you a seat.</p>
        </div>
        <form class="opm-newsletter-form" id="newsletterForm" novalidate>
          <input type="email" name="email" placeholder="you@example.com" required autocomplete="email" aria-label="Email" />
          <button type="submit">Subscribe</button>
        </form>
        <p class="opm-newsletter-msg" id="newsletterMsg" role="status" aria-live="polite"></p>
      </div>
    </section>

    <%- renderRow({
      title: "Browse by style",
      subtitle: "From Neapolitan to Detroit deep-dish",
      viewAllHref: "/styles",
      cards: styleCards,
    }) %>

    <!-- Blog row — placeholder until the Blog schema lands (see roadmap) -->
    <section class="opm-row opm-blog">
      <div class="opm-row-head">
        <div>
          <h2>From the blog</h2>
          <p class="opm-row-sub">Stories from the community kitchen</p>
        </div>
        <span class="opm-blog-soon">Coming soon</span>
      </div>
      <div class="opm-blog-grid">
        <% blogStubs.forEach(function (b) { %>
          <a class="opm-blog-card" href="<%= b.href %>">
            <div class="opm-blog-card-imgwrap">
              <img class="opm-blog-card-img" src="<%= b.image %>" alt="" loading="lazy"
                   onerror="this.onerror=null;this.src='<%= b.fallback %>';" />
            </div>
            <div class="opm-blog-card-body">
              <h3><%= b.title %></h3>
              <p class="opm-blog-card-meta"><%= b.meta %></p>
              <p class="opm-blog-card-excerpt"><%= b.excerpt %></p>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  </main>

  <footer class="opm-home-footer">
    <div class="opm-home-footer-inner">
      <div class="opm-home-footer-grid">
        <div class="opm-footer-col">
          <h4>About OpenPizzaMap</h4>
          <ul>
            <li><a href="/about">Who we are</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/map">The map</a></li>
            <li><a href="https://github.com/elehmanndev/OpenPizzaMap" rel="noopener">Open source on GitHub</a></li>
          </ul>
        </div>

        <div class="opm-footer-col">
          <h4>Top cities</h4>
          <ul>
            <% footerLinks.cities.forEach(function (l) { %>
              <li><a href="<%= l.href %>"><%= l.label %></a></li>
            <% }) %>
          </ul>
        </div>

        <div class="opm-footer-col">
          <h4>Countries</h4>
          <ul>
            <% footerLinks.countries.forEach(function (l) { %>
              <li><a href="<%= l.href %>"><%= l.label %></a></li>
            <% }) %>
          </ul>
        </div>

        <div class="opm-footer-col">
          <h4>Pizza styles</h4>
          <ul>
            <% footerLinks.styles.forEach(function (l) { %>
              <li><a href="<%= l.href %>"><%= l.label %></a></li>
            <% }) %>
          </ul>
        </div>

        <div class="opm-footer-col">
          <h4>Browse curated</h4>
          <ul>
            <% footerLinks.curated.forEach(function (l) { %>
              <li><a href="<%= l.href %>"><%= l.label %></a></li>
            <% }) %>
          </ul>
          <h4 class="opm-footer-subhead">Legal</h4>
          <ul>
            <li><a href="/privacy">Privacy</a></li>
            <li><a href="/terms">Terms</a></li>
          </ul>
        </div>
      </div>

      <div class="opm-home-footer-meta">
        <div class="opm-home-footer-brand">OpenPizzaMap</div>
        <p>Pizza opinions, not Yelp lectures. Open-source, community-curated.</p>
      </div>
    </div>
  </footer>

  <script>
    // Sidebar open/close (same logic as layout.ejs)
    (function () {
      var openBtn = document.getElementById('sidebar-open');
      var closeBtn = document.getElementById('sidebar-close');
      var backdrop = document.getElementById('sidebar-backdrop');
      var sidebar = document.getElementById('sidebar');
      if (!openBtn || !sidebar) return;
      function open() {
        sidebar.classList.add('is-open');
        backdrop.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        sidebar.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        document.body.style.overflow = '';
      }
      openBtn.addEventListener('click', open);
      closeBtn.addEventListener('click', close);
      backdrop.addEventListener('click', close);
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
    })();

    // Row arrow scrolling
    document.querySelectorAll('.opm-row-scroll, .opm-featured-track-wrap').forEach(function (scroll) {
      var track = scroll.querySelector('.opm-row-track, .opm-featured-track');
      if (!track) return;
      scroll.querySelectorAll('.opm-row-arrow').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dir = Number(btn.getAttribute('data-dir')) || 1;
          var step = Math.round(track.clientWidth * 0.8);
          track.scrollBy({ left: step * dir, behavior: 'smooth' });
        });
      });
    });

    // Newsletter signup → /api/notify
    (function () {
      var form = document.getElementById('newsletterForm');
      var msg = document.getElementById('newsletterMsg');
      if (!form) return;
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var btn = form.querySelector('button');
        var input = form.querySelector('input[name="email"]');
        var email = (input.value || '').trim();
        if (!email || !/.+@.+\..+/.test(email)) {
          msg.textContent = 'Please enter a valid email.';
          msg.className = 'opm-newsletter-msg err';
          return;
        }
        btn.disabled = true;
        msg.textContent = '';
        msg.className = 'opm-newsletter-msg';
        try {
          var res = await fetch('/api/notify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, source: 'home' })
          });
          var data = await res.json().catch(function () { return {}; });
          if (res.ok && data.ok) {
            msg.textContent = "You're in. Watch your inbox.";
            msg.className = 'opm-newsletter-msg ok';
            input.value = '';
          } else {
            msg.textContent = data.error || 'Something went wrong. Try again.';
            msg.className = 'opm-newsletter-msg err';
          }
        } catch (err) {
          msg.textContent = 'Network error. Try again.';
          msg.className = 'opm-newsletter-msg err';
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>
</body>
</html>
