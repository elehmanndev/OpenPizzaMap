<!doctype html>
<html>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= (typeof title === "string" && title.includes("OpenPizzaMap"))
      ? title
      : (title ? `${title} | OpenPizzaMap` : "OpenPizzaMap") %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= asset("/public/css/styles.css") %>" />
  <% if (leaflet) { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <% } %>
</head>

<body class="<%= (typeof bodyClass !== "undefined" && bodyClass) ? bodyClass : "" %>">
  <header>
    <div class="nav">
      <a href="/"><strong>OpenPizzaMap</strong></a>
    </div>
    <div class="header-actions">
      <% if (user) { %>
        <span class="greeting">Hi, <%= user.displayName %></span>
      <% } %>
      <details class="menu">
        <summary class="menu-toggle" aria-label="Open menu">
          <span class="material-symbols-rounded" aria-hidden="true">menu</span>
        </summary>
        <div class="menu-panel">
          <nav class="menu-links">
            <a href="/map">Map</a>
            <% if (user) { %>
              <a href="/add">Add</a>
              <a href="/me">My submissions</a>
              <a href="/favourites">My favourites</a>
              <% if (user.role==="admin" ) { %>
                <a href="/admin/places">Places</a>
                <a href="/admin/styles">Styles</a>
                <a href="/admin/pages">CMS</a>
              <% } %>
            <% } %>
          </nav>
          <% if (user) { %>
            <form method="post" action="/logout">
              <button type="submit" class="menu-logout">Logout</button>
            </form>
          <% } else { %>
            <div class="menu-auth">
              <a href="/auth">Sign in</a>
            </div>
          <% } %>
        </div>
      </details>
    </div>
  </header>
  <% const isAuthPage = typeof bodyClass === "string" && bodyClass.includes("auth-page"); %>
  <main class="container">
    <% if (isAuthPage) { %>
      <div class="auth-stack">
        <%- body %>
      </div>
    <% } else { %>
      <%- body %>
    <% } %>
  </main>
</body>

</html>
