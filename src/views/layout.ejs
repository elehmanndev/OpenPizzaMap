<!doctype html>
<html>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= title || "OpenPizzaMap" %>
  </title>
  <script>
    (function () {
      try {
        var theme = localStorage.getItem("theme");
        if (theme === "light" || theme === "dark") {
          document.documentElement.setAttribute("data-theme", theme);
        }
      } catch (err) {
        // ignore storage errors
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:wght@400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/styles.css?v=20260203" />
  <% if (leaflet) { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <% } %>
</head>

<body class="<%= (typeof bodyClass !== "undefined" && bodyClass) ? bodyClass : "" %>">
  <header>
    <div class="nav">
      <a href="/"><strong>OpenPizzaMap</strong></a>
      <a href="/map">Map</a>
      <% if (user) { %>
        <a href="/add">Add</a>
        <a href="/me">My submissions</a>
        <% if (user.role==="admin" ) { %>
          <a href="/admin/submissions">Admin</a>
          <% } %>
            <% } %>
    </div>
    <div>
      <% if (user) { %>
        <span class="small">Hi, <%= user.displayName %></span>
        <form method="post" action="/logout" style="display:inline;">
          <button type="submit">Logout</button>
        </form>
        <% } else { %>
          <a href="/login">Login</a> · <a href="/register">Register</a>
          <% } %>
    </div>
  </header>
  <% const isAuthPage = typeof bodyClass === "string" && bodyClass.includes("auth-page"); %>
  <main class="container">
    <% if (isAuthPage) { %>
      <div class="auth-stack">
        <%- body %>
        <div class="theme-toggle">
          <button type="button" class="theme-toggle-btn" data-theme-toggle aria-pressed="false">
            <span class="material-symbols-rounded" aria-hidden="true" data-theme-icon>dark_mode</span>
            <span data-theme-label>Switch to dark mode</span>
          </button>
        </div>
      </div>
    <% } else { %>
      <%- body %>
    <% } %>
  </main>
  <% if (!isAuthPage) { %>
    <div class="theme-toggle">
      <button type="button" class="theme-toggle-btn" data-theme-toggle aria-pressed="false">
        <span class="material-symbols-rounded" aria-hidden="true" data-theme-icon>dark_mode</span>
        <span data-theme-label>Switch to dark mode</span>
      </button>
    </div>
  <% } %>
  <script>
    (function () {
      var toggles = Array.from(document.querySelectorAll("[data-theme-toggle]"));
      if (!toggles.length) return;
      var root = document.documentElement;
      var getCurrent = function () {
        var current = root.getAttribute("data-theme");
        if (current === "light" || current === "dark") return current;
        return window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };
      var updateLabel = function () {
        var current = getCurrent();
        var isDark = current === "dark";
        toggles.forEach(function (toggle) {
          var icon = toggle.querySelector("[data-theme-icon]");
          var label = toggle.querySelector("[data-theme-label]");
          if (icon) icon.textContent = isDark ? "light_mode" : "dark_mode";
          if (label) label.textContent = isDark ? "Switch to light mode" : "Switch to dark mode";
          toggle.setAttribute("aria-pressed", isDark ? "true" : "false");
        });
      };
      toggles.forEach(function (toggle) {
        toggle.addEventListener("click", function () {
          var next = getCurrent() === "dark" ? "light" : "dark";
          root.setAttribute("data-theme", next);
          try {
            localStorage.setItem("theme", next);
          } catch (err) {
            // ignore storage errors
          }
          updateLabel();
        });
      });
      updateLabel();
    })();
  </script>
</body>

</html>
