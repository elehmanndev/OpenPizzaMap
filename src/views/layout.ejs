<!doctype html>
<html>

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= (typeof title === "string" && title.includes("OpenPizzaMap"))
      ? title
      : (title ? `${title} | OpenPizzaMap` : "OpenPizzaMap") %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="<%= asset("/public/css/styles.css") %>" />
  <% if (leaflet) { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
    <% } %>
</head>

<% const isAuthPage = typeof bodyClass === "string" && bodyClass.includes("auth-page"); %>
<body class="<%= (typeof bodyClass !== "undefined" && bodyClass) ? bodyClass : "" %>">
  <header>
    <div class="nav">
      <a href="/"><strong>OpenPizzaMap</strong></a>
    </div>
    <div class="header-actions">
      <% if (user) { %>
        <span class="greeting">Hi, <%= user.displayName %></span>
      <% } %>
      <% if (!isAuthPage) { %>
        <button class="menu-toggle" id="sidebar-open" aria-label="Open menu">
          <span class="material-symbols-rounded" aria-hidden="true">menu</span>
        </button>
      <% } %>
    </div>
  </header>

  <% if (!isAuthPage) { %>
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>
  <nav class="sidebar" id="sidebar" aria-label="Navigation">
    <div class="sidebar-head">
      <% if (user) { %>
        <div class="sidebar-user">
          <div class="sidebar-avatar"><%= (user.displayName || user.email || "?")[0].toUpperCase() %></div>
          <div class="sidebar-user-info">
            <div class="sidebar-user-name"><%= user.displayName || user.username %></div>
            <% if (user.username) { %><div class="sidebar-user-handle">@<%= user.username %></div><% } %>
          </div>
        </div>
      <% } else { %>
        <div class="sidebar-brand">OpenPizzaMap</div>
      <% } %>
      <button class="sidebar-close" id="sidebar-close" aria-label="Close menu">
        <span class="material-symbols-rounded">close</span>
      </button>
    </div>

    <div class="sidebar-links">
      <a href="/map" class="sidebar-link">
        <span class="material-symbols-rounded">map</span>
        Map
      </a>
      <% if (user) { %>
        <a href="/add-your-spot" class="sidebar-link">
          <span class="material-symbols-rounded">add_location_alt</span>
          Add your spot
        </a>
        <a href="/me" class="sidebar-link">
          <span class="material-symbols-rounded">person</span>
          My profile
        </a>
        <a href="/settings" class="sidebar-link">
          <span class="material-symbols-rounded">settings</span>
          Settings
        </a>
        <% if (user.role === "admin") { %>
          <div class="sidebar-section-label">Admin</div>
          <a href="/admin/places" class="sidebar-link">
            <span class="material-symbols-rounded">storefront</span>
            Places
          </a>
          <a href="/admin/styles" class="sidebar-link">
            <span class="material-symbols-rounded">style</span>
            Styles
          </a>
          <a href="/admin/submissions" class="sidebar-link">
            <span class="material-symbols-rounded">inbox</span>
            Submissions
          </a>
          <a href="/admin/merge" class="sidebar-link">
            <span class="material-symbols-rounded">merge</span>
            Merge duplicates
          </a>
        <% } %>
      <% } %>
    </div>

    <div class="sidebar-foot">
      <% if (user) { %>
        <form method="post" action="/logout">
          <button type="submit" class="sidebar-logout">
            <span class="material-symbols-rounded">logout</span>
            Sign out
          </button>
        </form>
      <% } else { %>
        <a href="/auth" class="sidebar-signin">Sign in</a>
      <% } %>
    </div>
  </nav>
  <% } %>

  <main class="container">
    <% if (isAuthPage) { %>
      <div class="auth-stack">
        <%- body %>
      </div>
    <% } else { %>
      <%- body %>
    <% } %>
  </main>

  <% if (!isAuthPage) { %>
  <script>
    (function () {
      const open = document.getElementById('sidebar-open');
      const close = document.getElementById('sidebar-close');
      const backdrop = document.getElementById('sidebar-backdrop');
      const sidebar = document.getElementById('sidebar');

      function openSidebar() {
        sidebar.classList.add('is-open');
        backdrop.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        sidebar.classList.remove('is-open');
        backdrop.classList.remove('is-open');
        document.body.style.overflow = '';
      }

      open.addEventListener('click', openSidebar);
      close.addEventListener('click', closeSidebar);
      backdrop.addEventListener('click', closeSidebar);

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeSidebar();
      });
    })();
  </script>
  <% } %>
</body>

</html>
