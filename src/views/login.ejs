<%- include("layout", { title: "Login", user, leaflet: false, bodyClass: "auth-page", body: String.raw`
<section class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand">
      <span class="auth-logo">OPM</span>
      <div>
        <span class="auth-brand-name">OpenPizzaMap</span>
        <span class="auth-brand-tag">Your pizza intel hub</span>
      </div>
    </div>
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Sign in to keep your slice map up to date.</p>
    ${googleAuthEnabled ? String.raw`
      <a class="auth-social" href="/api/auth/google">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.2-.9 2.1-1.9 2.8v2.3h3.1c1.8-1.6 2.9-4 2.9-6.9 0-.7-.1-1.4-.2-2.1H12z"/>
          <path fill="#34A853" d="M12 22c2.6 0 4.8-.9 6.4-2.5l-3.1-2.3c-.9.6-2 .9-3.3.9-2.5 0-4.6-1.7-5.4-4.1H3.4v2.6C5 19.9 8.2 22 12 22z"/>
          <path fill="#4A90E2" d="M6.6 13.9c-.2-.6-.3-1.3-.3-1.9s.1-1.3.3-1.9V7.5H3.4C2.8 8.8 2.4 10.4 2.4 12s.4 3.2 1 4.5l3.2-2.6z"/>
          <path fill="#FBBC05" d="M12 5.8c1.4 0 2.6.5 3.6 1.4l2.7-2.7C16.8 2.8 14.6 2 12 2 8.2 2 5 4.1 3.4 7.5l3.2 2.6C7.4 7.5 9.5 5.8 12 5.8z"/>
        </svg>
        Continue with Google
      </a>
    ` : String.raw`
      <button class="auth-social" type="button" disabled aria-disabled="true">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.2-.9 2.1-1.9 2.8v2.3h3.1c1.8-1.6 2.9-4 2.9-6.9 0-.7-.1-1.4-.2-2.1H12z"/>
          <path fill="#34A853" d="M12 22c2.6 0 4.8-.9 6.4-2.5l-3.1-2.3c-.9.6-2 .9-3.3.9-2.5 0-4.6-1.7-5.4-4.1H3.4v2.6C5 19.9 8.2 22 12 22z"/>
          <path fill="#4A90E2" d="M6.6 13.9c-.2-.6-.3-1.3-.3-1.9s.1-1.3.3-1.9V7.5H3.4C2.8 8.8 2.4 10.4 2.4 12s.4 3.2 1 4.5l3.2-2.6z"/>
          <path fill="#FBBC05" d="M12 5.8c1.4 0 2.6.5 3.6 1.4l2.7-2.7C16.8 2.8 14.6 2 12 2 8.2 2 5 4.1 3.4 7.5l3.2 2.6C7.4 7.5 9.5 5.8 12 5.8z"/>
        </svg>
        Continue with Google
      </button>
    `}
    <div class="auth-divider"><span>or continue with email</span></div>
    <form class="auth-form" id="login" novalidate>
      <label class="auth-field">
        <span>Email address</span>
        <input name="email" type="email" autocomplete="email" required />
        <small class="auth-error" aria-live="polite"></small>
      </label>
      <label class="auth-field">
        <span>Password</span>
        <div class="auth-password">
          <input name="password" type="password" autocomplete="current-password" required minlength="8" maxlength="128" pattern="^(?=.*[A-Za-z])(?=.*[0-9]).+$" />
          <button class="auth-toggle" type="button" aria-label="Show password" aria-pressed="false" data-password-toggle>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 5c5.2 0 9.4 3.3 11 7-1.6 3.7-5.8 7-11 7S2.6 15.7 1 12c1.6-3.7 5.8-7 11-7zm0 2c-3.9 0-7.3 2.3-8.8 5 1.5 2.7 4.9 5 8.8 5s7.3-2.3 8.8-5c-1.5-2.7-4.9-5-8.8-5zm0 2.5A2.5 2.5 0 1 1 12 16a2.5 2.5 0 0 1 0-5z"/>
            </svg>
          </button>
        </div>
        <small class="auth-hint">At least 8 characters with letters and numbers.</small>
        <small class="auth-error" aria-live="polite"></small>
      </label>
      <button class="auth-submit" type="submit">Sign in</button>
      <p class="auth-msg" id="msg"></p>
    </form>
    <p class="auth-footer" id="forgot-wrap" hidden><a href="/forgot">I forgot my password</a></p>
    <p class="auth-footer">New here? <a href="/register">Create an account</a></p>
  </div>
</section>
<script>
  const form = document.getElementById("login");
  const msg = document.getElementById("msg");
  const forgotWrap = document.getElementById("forgot-wrap");
  const fields = Array.from(form.querySelectorAll("input"));
  let submitted = false;
  const FAIL_KEY = "opm_login_fails";
  const getFails = () => Number(sessionStorage.getItem(FAIL_KEY) || 0);
  const setFails = (value) => sessionStorage.setItem(FAIL_KEY, String(value));
  const updateForgotVisibility = () => {
    if (!forgotWrap) return;
    forgotWrap.hidden = getFails() < 3;
  };
  const getMessage = (input) => {
    const value = input.value.trim();
    if (input.validity.valueMissing) {
      if (input.name === "email") return "Email is required.";
      if (input.name === "password") return "Password is required.";
    }
    if (input.name === "email" && (input.validity.typeMismatch || input.validity.patternMismatch)) {
      return "\"" + (value || "This") + "\" isn't a valid email address.";
    }
    if (input.name === "password" && (input.validity.tooShort || input.validity.patternMismatch)) {
      return "Password must be at least 8 characters and include letters and numbers.";
    }
    return input.validationMessage || "Please check this field.";
  };
  const updateValidity = (input) => {
    const field = input.closest(".auth-field");
    const error = field ? field.querySelector(".auth-error") : null;
    const isValid = input.checkValidity();
    const hasValue = input.value.trim().length > 0;
    const showError = submitted && (!isValid);
    input.classList.toggle("is-valid", isValid && hasValue);
    input.classList.toggle("is-invalid", !isValid && hasValue);
    if (field) field.classList.toggle("is-invalid", submitted && !isValid);
    if (error && showError) {
      error.textContent = getMessage(input);
    } else if (error) {
      error.textContent = "";
    }
  };
  fields.forEach((input) => {
    input.addEventListener("input", () => updateValidity(input));
  });
  const toggles = Array.from(document.querySelectorAll("[data-password-toggle]"));
  toggles.forEach((btn) => {
    const field = btn.closest(".auth-field");
    const input = field ? field.querySelector("input") : null;
    if (!input) return;
    btn.addEventListener("click", () => {
      const isText = input.type === "text";
      input.type = isText ? "password" : "text";
      btn.setAttribute("aria-pressed", String(!isText));
      btn.setAttribute("aria-label", isText ? "Show password" : "Hide password");
      btn.classList.toggle("is-on", !isText);
    });
  });
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    msg.textContent = "";
    submitted = true;
    fields.forEach((input) => updateValidity(input));
    if (!form.checkValidity()) {
      msg.textContent = "Please fix the highlighted fields.";
      return;
    }
    const fd = new FormData(form);
    const body = Object.fromEntries(fd.entries());
    const res = await fetch("/api/auth/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (data.ok) {
      setFails(0);
      updateForgotVisibility();
      location.href = "/";
      return;
    }
    setFails(getFails() + 1);
    updateForgotVisibility();
    if (typeof data.error === "string") {
      msg.textContent = data.error;
    } else if (data.error && data.error.formErrors && data.error.formErrors.length) {
      msg.textContent = data.error.formErrors.join(", ");
    } else if (data.error && data.error.fieldErrors) {
      msg.textContent = Object.values(data.error.fieldErrors).flat().join(", ");
    } else {
      msg.textContent = "Login failed";
    }
  });
  updateForgotVisibility();
</script>
` }) %>
