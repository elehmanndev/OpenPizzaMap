<%- include("layout", { title: "Map", user, leaflet: true, bodyClass: "map-page", body: `
    <div class="map-shell">
      <aside class="map-sidebar" aria-label="Pizza spots">
        <button type="button" class="map-sheet-handle" aria-label="Drag to resize list">
          <span class="map-sheet-handle-grip" aria-hidden="true"></span>
        </button>
        <div class="map-sidebar-header">
          <div class="map-search-wrap">
            <form class="map-search" role="search" autocomplete="off">
              <span class="material-symbols-rounded map-search-icon" aria-hidden="true">search</span>
              <input type="search" name="q" class="map-search-input" placeholder="Search pizza, city…" aria-label="Search pizza spots" />
              <button type="button" class="map-search-clear" aria-label="Clear" hidden>
                <span class="material-symbols-rounded" aria-hidden="true">close</span>
              </button>
            </form>
            <div class="map-search-suggest" hidden>
              <section class="map-suggest-section" data-suggest-cities>
                <h4 class="map-suggest-title">Cities</h4>
                <ul class="map-suggest-list"></ul>
              </section>
              <section class="map-suggest-section" data-suggest-spots>
                <h4 class="map-suggest-title">Spots</h4>
                <ul class="map-suggest-list"></ul>
              </section>
              <div class="map-suggest-empty" hidden>No matches</div>
            </div>
          </div>
          <div class="map-controls">
            <details class="map-sort-dropdown">
              <summary class="map-sort-summary">
                <span class="map-sort-summary-label">Sort</span>
                <span class="material-symbols-rounded map-sort-caret" aria-hidden="true">expand_more</span>
              </summary>
              <div class="map-sort-menu" role="radiogroup" aria-label="Sort by">
                <label class="map-sort-opt"><input type="radio" name="map-sort" value="popular" checked /><span class="map-sort-opt-label">Popular</span></label>
                <label class="map-sort-opt"><input type="radio" name="map-sort" value="rating" /><span class="map-sort-opt-label">Rating</span></label>
                <label class="map-sort-opt"><input type="radio" name="map-sort" value="distance-city" /><span class="map-sort-opt-label">Distance from city</span></label>
                <label class="map-sort-opt"><input type="radio" name="map-sort" value="distance-me" /><span class="map-sort-opt-label">Near me</span></label>
                <label class="map-sort-opt"><input type="radio" name="map-sort" value="price-asc" /><span class="map-sort-opt-label">Price ↑</span></label>
                <label class="map-sort-opt"><input type="radio" name="map-sort" value="price-desc" /><span class="map-sort-opt-label">Price ↓</span></label>
              </div>
            </details>
            <details class="map-style-dropdown">
              <summary class="map-style-summary">
                <span class="map-style-summary-label">Styles</span>
                <span class="map-style-summary-count" hidden></span>
                <span class="material-symbols-rounded map-style-caret" aria-hidden="true">expand_more</span>
              </summary>
              <div class="map-style-menu" role="group" aria-label="Filter by style"></div>
            </details>
          </div>
          <div class="map-result-count" aria-live="polite"></div>
        </div>
        <div class="map-sidebar-list" role="list"></div>
        <div class="map-sidebar-empty" hidden>
          <p>No pizza spots in this area.</p>
          <button type="button" class="map-zoom-out">Zoom out</button>
        </div>
      </aside>
      <div class="map-canvas">
        <div id="map" aria-label="Pizza map"></div>
      </div>
    </div>
    <script>window.__OPM_USER__ = ${user ? "true" : "false"};</script>
    <script src="${asset("/public/js/map.js")}"></script>
` }) %>
