const initials = (account.displayName || account.username || "?")
    .trim()
    .split(/\s+/)
    .map((w) => w[0])
    .filter(Boolean)
    .slice(0, 2)
    .join("")
    .toUpperCase();

const memberSince = account.createdAt
    ? new Date(account.createdAt).toLocaleDateString(undefined, { month: "short", year: "numeric" })
    : "";

// ────────────────────────────────────────────────────────────────
// Passport-stamp card for the Visited section. Each stamp shows:
//   city name · landmark icon · country
// Icon source comes from City.iconSlug (svg:<file> or mingcute:<name>);
// missing → falls back to the generic pizza-slice stamp. Ink color is
// picked deterministically from an 8-colour palette via the city slug
// hash, so the same city always lands the same colour across the rail.
//
// See docs/preview-traced-stamps.html for the visual reference and
// public/img/stamps/ for the 19 traced SVGs that ship with this view.
// ────────────────────────────────────────────────────────────────
const STAMP_INK_PALETTE = [
    "#c9483a", // pizza red
    "#1e3a8a", // deep navy
    "#2d6e5c", // basil green
    "#a8741e", // spanish ochre
    "#7b3961", // burgundy wine
    "#2d6770", // vintage teal
    "#6b4423", // sepia brown
    "#5f4b8b", // faded violet
];
function pickInkColor(citySlug) {
    const key = String(citySlug || "fallback");
    let h = 0;
    for (let i = 0; i < key.length; i++) h = ((h * 31) + key.charCodeAt(i)) | 0;
    return STAMP_INK_PALETTE[Math.abs(h) % STAMP_INK_PALETTE.length];
}
function pickTilt(citySlug, idx) {
    const key = String(citySlug || idx);
    let h = 0;
    for (let i = 0; i < key.length; i++) h = ((h * 17) + key.charCodeAt(i)) | 0;
    const sign = (h & 1) ? -1 : 1;
    return sign * (3 + (Math.abs(h) % 5));
}
function stampIconHtml(iconSlug) {
    if (!iconSlug) {
        return `<iconify-icon class="opm-stamp__icon" icon="mingcute:pizza-line"></iconify-icon>`;
    }
    if (iconSlug.startsWith("svg:")) {
        const file = iconSlug.slice(4);
        return `<span class="opm-stamp__icon opm-stamp__icon--svg" style="--stamp-icon: url('/img/stamps/${file}.svg')"></span>`;
    }
    return `<iconify-icon class="opm-stamp__icon" icon="${escapeAttr(iconSlug)}"></iconify-icon>`;
}
function stampMonthYear(d) {
    if (!d) return "";
    const date = new Date(d);
    const m = date.toLocaleString("en-US", { month: "short" }).toUpperCase();
    return `${m}·${date.getFullYear()}`;
}
function stampCard(place, when, idx) {
    const citySlug = (place.cityRef && place.cityRef.slug) || (place.city || "").toLowerCase().replace(/\s+/g, "-");
    const iconSlug = place.cityRef && place.cityRef.iconSlug;
    const ink = pickInkColor(citySlug);
    const tilt = pickTilt(citySlug, idx);
    const country = place.country || "";
    return `
      <a class="opm-stamp-item" href="/place/${place.id}">
        <div class="opm-stamp" style="color: ${ink}; transform: rotate(${tilt}deg);">
          <span class="opm-stamp__city">${escapeHtml(place.city || place.name)}</span>
          ${stampIconHtml(iconSlug)}
          <span class="opm-stamp__divider"></span>
          <span class="opm-stamp__country">${escapeHtml(country)}</span>
        </div>
        <div class="opm-stamp__place">${escapeHtml(place.name)}</div>
        <div class="opm-stamp__date">${stampMonthYear(when)}</div>
      </a>
    `;
}

// ────────────────────────────────────────────────────────────────
// Review card for the "My reviews" rail. Inspired by Airbnb host
// reviews — place photo as the avatar, name + city, date, rating
// dots, review text truncated to ~7 lines.
// ────────────────────────────────────────────────────────────────
function fmtMonthYear(d) {
    if (!d) return "";
    const date = new Date(d);
    return date.toLocaleDateString(undefined, { month: "short", year: "numeric" });
}
function ratingDots(value) {
    const v = Math.max(0, Math.min(5, Number(value) || 0));
    const full = Math.floor(v);
    const half = (v - full) >= 0.5;
    let html = "";
    for (let i = 0; i < full; i++) html += "●";
    if (half && full < 5) { html += `<span class="opm-dots--half">●</span>`; }
    const remaining = 5 - full - (half ? 1 : 0);
    for (let i = 0; i < remaining; i++) html += `<span class="opm-dots--empty">●</span>`;
    return html;
}
function reviewCard(r) {
    const avg = ((Number(r.pizza) + Number(r.local) + Number(r.servicio) + Number(r.precio)) / 4);
    const where = [r.place.city, r.place.country].filter(Boolean).join(", ");
    return `
      <a class="opm-review-card" href="/place/${r.place.id}">
        <div class="opm-review__head">
          <span class="opm-review__rating" title="${avg.toFixed(1)} / 5 (avg of pizza, setting, service, value)"><strong>${avg.toFixed(1)}</strong></span>
          <div class="opm-review__id">
            <span class="opm-review__name">${escapeHtml(r.place.name)}</span>
            ${where ? `<span class="opm-review__where">${escapeHtml(where)}</span>` : ""}
          </div>
        </div>
        <div class="opm-review__dots">${ratingDots(avg)}</div>
        <div class="opm-review__date">${escapeHtml(fmtMonthYear(r.visitedAt || r.createdAt))}</div>
        ${r.comment ? `<p class="opm-review__text">${escapeHtml(r.comment)}</p>` : `<p class="opm-review__text opm-review__text--muted"><em>No comment</em></p>`}
      </a>
    `;
}

// ────────────────────────────────────────────────────────────────
// Wishlist scard — photo on top + name + city + saved-date pill.
// ────────────────────────────────────────────────────────────────
function wishlistCard(fav) {
    const place = fav.place;
    const photo = place.heroImageUrl;
    const where = [place.city, place.country].filter(Boolean).join(", ");
    return `
      <a class="opm-wish-card" href="/place/${place.id}">
        <div class="opm-wish__img" ${photo ? `style="background-image:url('${escapeAttr(photo)}')"` : ""}>
          <span class="opm-wish__fav" aria-hidden="true">♥</span>
          <span class="opm-wish__saved">Saved ${escapeHtml(fmtMonthYear(fav.createdAt))}</span>
        </div>
        <div class="opm-wish__body">
          <div class="opm-wish__name">${escapeHtml(place.name)}</div>
          ${where ? `<div class="opm-wish__where">${escapeHtml(where)}</div>` : ""}
        </div>
      </a>
    `;
}
%>
<%- include("layout", { title: "My profile", user, leaflet: false, bodyClass: "profile-page", body: String.raw`
<section class="profile-wrap profile-wrap--v2">

  <!-- ─── Profile header · avatar + identity + inline counts ─────── -->
  <section class="profile-header profile-header--v2">
    <div class="profile-avatar" data-profile-avatar>
      ${account.avatarUrl
          ? `<img src="${escapeAttr(account.avatarUrl)}" alt="" referrerpolicy="no-referrer" data-profile-avatar-img />`
          : `<span class="profile-avatar-initials" data-profile-avatar-initials>${escapeHtml(initials)}</span>`}
      <label class="profile-avatar-edit" title="Change profile picture">
        <span class="material-symbols-rounded" aria-hidden="true">photo_camera</span>
        <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp,image/gif,image/avif" data-profile-avatar-input hidden />
      </label>
    </div>
    <div class="profile-identity">
      <h1 class="profile-name">${escapeHtml(account.displayName || account.username || "Pizza fan")}</h1>
      ${account.username ? `<div class="profile-username">@${escapeHtml(account.username)}</div>` : ""}
      ${memberSince ? `<div class="profile-since">Member since ${escapeHtml(memberSince)}</div>` : ""}
    </div>
    <div class="profile-counts">
      <a class="profile-count" href="#section-visited">
        <span class="profile-count__num">${counts.been}</span>
        <span class="profile-count__label">Visited</span>
      </a>
      <a class="profile-count" href="#section-reviews">
        <span class="profile-count__num">${counts.reviews}</span>
        <span class="profile-count__label">Reviews</span>
      </a>
      <a class="profile-count" href="#section-wishlist">
        <span class="profile-count__num">${counts.wishlist}</span>
        <span class="profile-count__label">Wishlist</span>
      </a>
    </div>
  </section>

  <!-- ─── 1. Visited · passport stamps ────────────────────────────── -->
  <section class="opm-section" id="section-visited">
    <div class="opm-section__head">
      <h2 class="opm-section__title">Visited</h2>
    </div>
    ${beenThere.length
        ? `<div class="opm-rail-wrap" data-rail-wrap>
             <button class="opm-rail-arrow opm-rail-arrow--prev" data-rail-prev type="button" aria-label="Scroll left" hidden>‹</button>
             <div class="opm-stamps-rail" data-rail>${beenThere.map((b, i) => stampCard(b.place, b.visitedAt, i)).join("")}</div>
             <button class="opm-rail-arrow opm-rail-arrow--next" data-rail-next type="button" aria-label="Scroll right" hidden>›</button>
           </div>`
        : `<div class="profile-empty">
             <strong>No visits logged yet.</strong>
             <span>Mark a place as visited from its page to start your map.</span>
             <a class="profile-cta" href="/map">Find a slice</a>
           </div>`}
  </section>

  <!-- ─── 2. My reviews · review cards rail ───────────────────────── -->
  <section class="opm-section" id="section-reviews">
    <div class="opm-section__head">
      <h2 class="opm-section__title">My reviews</h2>
    </div>
    ${reviews.length
        ? `<div class="opm-rail-wrap" data-rail-wrap>
             <button class="opm-rail-arrow opm-rail-arrow--prev" data-rail-prev type="button" aria-label="Scroll left" hidden>‹</button>
             <div class="opm-reviews-rail" data-rail>${reviews.map(reviewCard).join("")}</div>
             <button class="opm-rail-arrow opm-rail-arrow--next" data-rail-next type="button" aria-label="Scroll right" hidden>›</button>
           </div>`
        : `<div class="profile-empty">
             <strong>No reviews yet.</strong>
             <span>Rate a place once you've tried it — your review helps the community.</span>
           </div>`}
  </section>

  <!-- ─── 3. Wishlist · saved-place scards ────────────────────────── -->
  <section class="opm-section" id="section-wishlist">
    <div class="opm-section__head">
      <h2 class="opm-section__title">Wishlist</h2>
    </div>
    ${wishlist.length
        ? `<div class="opm-rail-wrap" data-rail-wrap>
             <button class="opm-rail-arrow opm-rail-arrow--prev" data-rail-prev type="button" aria-label="Scroll left" hidden>‹</button>
             <div class="opm-wish-rail" data-rail>${wishlist.map(wishlistCard).join("")}</div>
             <button class="opm-rail-arrow opm-rail-arrow--next" data-rail-next type="button" aria-label="Scroll right" hidden>›</button>
           </div>`
        : `<div class="profile-empty">
             <strong>Nothing on your wishlist yet.</strong>
             <span>Tap the heart on any pizzeria to save it for later.</span>
             <a class="profile-cta" href="/map">Browse the map</a>
           </div>`}
  </section>

  <footer class="profile-footer">
    <form action="/api/auth/logout" method="post" id="logout-form">
      <button type="button" id="logout-btn" class="profile-logout">Sign out</button>
    </form>
  </footer>
</section>

<!-- Iconify web component for the mingcute:* fallback stamp icons. -->
<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" async></script>

<style>
  /* ─── Profile header v2 — avatar + identity + counts in one card ─ */
  .profile-header--v2 {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
  }
  .profile-header--v2 .profile-identity { flex: 1; min-width: 200px; }
  .profile-counts {
    display: flex;
    gap: 22px;
    padding-left: 22px;
    border-left: 1px solid var(--line, #e8e6e0);
    flex-shrink: 0;
  }
  .profile-count {
    text-align: center;
    min-width: 56px;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .profile-count__num {
    display: block;
    font-size: 24px;
    font-weight: 700;
    color: var(--accent, #c9483a);
    line-height: 1;
  }
  .profile-count__label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute, #888);
    margin-top: 5px;
    font-weight: 500;
  }
  @media (max-width: 540px) {
    .profile-counts {
      border-left: none;
      border-top: 1px solid var(--line, #e8e6e0);
      padding-left: 0;
      padding-top: 14px;
      margin-top: 6px;
      width: 100%;
      justify-content: space-around;
    }
  }

  /* ─── Section chrome ─────────────────────────────────────────────── */
  .opm-section { margin: 28px 0; }
  .opm-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .opm-section__title {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
  }

  /* ─── Visited · passport stamps ─────────────────────────────────── */
  .opm-stamps-rail {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px 14px;
    padding: 8px 4px 16px;
  }
  @media (min-width: 720px) {
    .opm-stamps-rail {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 12px;
      margin: 0 -4px;
      padding-left: 4px;
      padding-right: 4px;
    }
    .opm-stamps-rail > * { flex: 0 0 168px; scroll-snap-align: start; }
  }
  .opm-stamps-rail::-webkit-scrollbar { display: none; }
  .opm-stamps-rail { scrollbar-width: none; }

  .opm-stamp-item {
    text-decoration: none;
    color: inherit;
    text-align: center;
    display: block;
  }
  .opm-stamp {
    width: 144px;
    height: 144px;
    border-radius: 50%;
    border: 3.5px solid currentColor;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 11px;
    margin: 0 auto 10px;
    background: transparent;
    opacity: 0.92;
    filter: contrast(1.05);
  }
  .opm-stamp::before {
    content: "";
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    opacity: 0.45;
    pointer-events: none;
  }
  .opm-stamp::after {
    content: "";
    position: absolute;
    inset: -7px;
    border-radius: 50%;
    border: 1px dashed currentColor;
    opacity: 0.18;
    pointer-events: none;
  }
  .opm-stamp__city {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
  }
  .opm-stamp__divider {
    width: 38%;
    border-top: 1px solid currentColor;
    margin: 5px auto 4px;
    opacity: 0.4;
  }
  .opm-stamp__country {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    opacity: 0.75;
  }
  .opm-stamp__icon {
    width: 46px;
    height: 46px;
    margin: 4px 0 2px;
    color: currentColor;
    display: inline-block;
  }
  iconify-icon.opm-stamp__icon {
    font-size: 56px;
    line-height: 1;
    width: 56px;
    height: 56px;
    margin: -2px 0;
  }
  .opm-stamp__icon--svg {
    background-color: currentColor;
    -webkit-mask: var(--stamp-icon) center / contain no-repeat;
    mask: var(--stamp-icon) center / contain no-repeat;
  }
  .opm-stamp__place {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 1px;
    line-height: 1.25;
  }
  .opm-stamp__date {
    font-size: 11.5px;
    color: var(--ink-mute, #888);
    letter-spacing: 0.04em;
  }

  /* ─── Rail-wrap chrome: position context for the scroll arrows ───── */
  .opm-rail-wrap {
    position: relative;
  }
  .opm-rail-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: white;
    border: 1px solid var(--line, #e8e6e0);
    box-shadow: 0 2px 8px rgba(0,0,0,.12);
    color: var(--ink, #1a1a1a);
    font-size: 22px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    font-family: inherit;
    padding: 0;
    padding-bottom: 4px;
  }
  .opm-rail-arrow:hover { background: #fafaf7; }
  .opm-rail-arrow:disabled { opacity: 0.35; cursor: default; }
  .opm-rail-arrow[hidden] { display: none; }
  .opm-rail-arrow--prev { left: -6px; }
  .opm-rail-arrow--next { right: -6px; }
  @media (max-width: 720px) {
    /* Hide arrows on mobile — swipe is the natural gesture */
    .opm-rail-arrow { display: none; }
  }

  /* ─── My reviews · carousel of review cards ─────────────────────── */
  .opm-reviews-rail {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 4px 4px 16px;
    margin: 0 -4px;
    scroll-behavior: smooth;
  }
  .opm-reviews-rail::-webkit-scrollbar { display: none; }
  .opm-reviews-rail { scrollbar-width: none; }
  .opm-review-card {
    flex: 0 0 260px;
    scroll-snap-align: start;
    padding: 14px 16px 16px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--line, #e8e6e0);
    border-radius: 12px;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .opm-review-card:hover {
    box-shadow: 0 4px 12px rgba(0,0,0,.08);
    transform: translateY(-1px);
  }
  .opm-review__head {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
  }
  /* OPM-style rating badge — replaces the photo avatar */
  .opm-review__rating {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--accent, #c9483a);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.01em;
    box-shadow: 0 1px 3px rgba(201,72,58,.25);
  }
  .opm-review__rating strong { font-weight: 700; }
  .opm-review__id { display: flex; flex-direction: column; min-width: 0; flex: 1; }
  .opm-review__name {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .opm-review__where {
    font-size: 12.5px;
    color: var(--ink-mute, #888);
    margin-top: 1px;
  }
  .opm-review__dots {
    color: var(--accent, #c9483a);
    letter-spacing: -1.5px;
    font-size: 14px;
    margin-bottom: 4px;
  }
  .opm-dots--empty { color: #e1c8c4; }
  .opm-dots--half  { color: var(--accent, #c9483a); opacity: 0.5; }
  .opm-review__date {
    font-size: 12.5px;
    color: var(--ink-mute, #888);
    margin-bottom: 8px;
  }
  .opm-review__text {
    font-size: 14px;
    color: #555;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 7;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .opm-review__text--muted { color: #aaa; }

  /* ─── Wishlist · scards (photo + name + saved pill) ─────────────── */
  .opm-wish-rail {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 720px) {
    .opm-wish-rail {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 6px;
      margin: 0 -4px;
      padding-left: 4px;
      padding-right: 4px;
    }
    .opm-wish-rail > * { flex: 0 0 220px; scroll-snap-align: start; }
  }
  .opm-wish-rail::-webkit-scrollbar { display: none; }
  .opm-wish-rail { scrollbar-width: none; }
  .opm-wish-card {
    background: white;
    border: 1px solid var(--line, #e8e6e0);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(0,0,0,.04);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .opm-wish__img {
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
    background-color: #f1ede4;
    position: relative;
  }
  .opm-wish__fav {
    position: absolute;
    top: 8px; right: 8px;
    background: rgba(255,255,255,0.95);
    border-radius: 50%;
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent, #c9483a);
    font-size: 14px;
    box-shadow: 0 2px 6px rgba(0,0,0,.12);
  }
  .opm-wish__saved {
    position: absolute;
    bottom: 8px; left: 8px;
    background: rgba(255,255,255,0.95);
    color: #555;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
  }
  .opm-wish__body {
    padding: 10px 11px 12px;
  }
  .opm-wish__name {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 3px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .opm-wish__where {
    font-size: 12px;
    color: var(--ink-mute, #888);
  }
</style>

<script>
  (function () {
    // Wire scroll chevrons on each rail. Each wrap contains:
    //   <button data-rail-prev> + <div data-rail> + <button data-rail-next>
    // The arrows scroll the rail by ~80% of its width and show/hide
    // themselves based on whether more content exists in that direction.
    document.querySelectorAll("[data-rail-wrap]").forEach((wrap) => {
      const rail = wrap.querySelector("[data-rail]");
      const prev = wrap.querySelector("[data-rail-prev]");
      const next = wrap.querySelector("[data-rail-next]");
      if (!rail || !prev || !next) return;

      function updateArrows() {
        const maxScroll = rail.scrollWidth - rail.clientWidth;
        const overflowing = maxScroll > 4;
        // Show next arrow when there's anywhere to scroll right.
        // Show prev arrow only when we've already scrolled some.
        if (!overflowing) {
          prev.hidden = true;
          next.hidden = true;
          return;
        }
        prev.hidden = rail.scrollLeft <= 4;
        next.hidden = rail.scrollLeft >= maxScroll - 4;
      }

      function scrollByAmount(dir) {
        const amount = Math.max(200, Math.round(rail.clientWidth * 0.8));
        rail.scrollBy({ left: dir * amount, behavior: "smooth" });
      }

      prev.addEventListener("click", () => scrollByAmount(-1));
      next.addEventListener("click", () => scrollByAmount(1));
      rail.addEventListener("scroll", updateArrows, { passive: true });
      window.addEventListener("resize", updateArrows);
      // Initial state — wait one tick so layout settled.
      setTimeout(updateArrows, 50);
    });

    const logoutBtn = document.getElementById("logout-btn");
    if (logoutBtn) {
      logoutBtn.addEventListener("click", async () => {
        try {
          await fetch("/api/auth/logout", { method: "POST" });
        } catch (_e) {}
        location.href = "/";
      });
    }

    // Avatar upload. Single hidden <input type=file> next to the avatar;
    // the camera icon label triggers it. On change → POST multipart to
    // /api/auth/avatar → swap the image in place + cache-bust.
    const avatarInput = document.querySelector("[data-profile-avatar-input]");
    const avatarBox = document.querySelector("[data-profile-avatar]");
    if (avatarInput && avatarBox) {
      avatarInput.addEventListener("change", async () => {
        const file = avatarInput.files && avatarInput.files[0];
        if (!file) return;
        avatarBox.classList.add("is-uploading");
        try {
          const fd = new FormData();
          fd.append("avatar", file);
          const resp = await fetch("/api/auth/avatar", { method: "POST", body: fd });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || data.ok === false) {
            alert(data.error || "Couldn't upload that picture.");
            return;
          }
          let img = avatarBox.querySelector("[data-profile-avatar-img]");
          if (!img) {
            avatarBox.querySelectorAll("[data-profile-avatar-initials]").forEach((n) => n.remove());
            img = document.createElement("img");
            img.setAttribute("data-profile-avatar-img", "");
            img.setAttribute("referrerpolicy", "no-referrer");
            img.alt = "";
            avatarBox.insertBefore(img, avatarBox.firstChild);
          }
          img.src = data.avatarUrl;
        } catch (err) {
          alert("Upload failed. Try again.");
        } finally {
          avatarBox.classList.remove("is-uploading");
          avatarInput.value = "";
        }
      });
    }
  })();
</script>
