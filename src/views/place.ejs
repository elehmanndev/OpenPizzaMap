<%
  // Map a hero URL like /uploads/places/123.jpg → /uploads/places/123-large.jpg.
  // Generated by scripts/build-thumbs.js (1200 px, q82) — much lighter than
  // the originals (some > 20 MB). External URLs and unknown extensions pass
  // through; the <img onerror> handler falls back to the original on 404.
  function largeVariant(url) {
    if (!url || typeof url !== "string") return url;
    if (!url.startsWith("/uploads/places/")) return url;
    const m = url.match(/^(.*)\.(jpe?g|png|webp|gif|avif)$/i);
    if (!m) return url;
    if (/-(thumb|large)$/.test(m[1])) return url;
    return `${m[1]}-large.jpg`;
  }

  // Parse opening hours from any of the formats we end up with in the DB:
  //   1. OSM-strict (legacy importer):  "Mo 13:00-17:00; Tu 19:00-23:00"
  //   2. GMaps localised weekly:        "domingo: 19:30-23:30; lunes: Cerrado; ..."
  //                                     also Italian/French/German/English/Portuguese
  //   3. GMaps multi-shift glued:       "viernes: 12:30-16:0019:00-24:00"
  //                                     (no separator between shifts in the source)
  //   4. GMaps today-only summary:      "Cerrado · Apertura: 18:30·Ver más horarios"
  //                                     → null, we don't have the full week
  // Returns rows that collapse runs of consecutive identical schedules into ranges.
  function parseOpeningHours(raw) {
    if (!raw) return null;
    const s = String(raw).replace(/ /g, " ").trim();
    if (!s) return null;
    // Bail on the today-only abbreviated GMaps summary — no full week available.
    if (/Ver más horarios|See more times|Vedi altri orari|Voir plus d'horaires|Weitere Öffnungszeiten/i.test(s)) return null;

    const dayLabels = { Mo: "Mon", Tu: "Tue", We: "Wed", Th: "Thu", Fr: "Fri", Sa: "Sat", Su: "Sun" };
    const order = ["Mo", "Tu", "We", "Th", "Fr", "Sa", "Su"];

    // Day-name dictionary: localised → ISO short code. Lower-cased lookup,
    // accent-stripped to handle "miércoles" / "miercoles" / "Sábado" / "sabado".
    const dayMap = {
      // OSM-strict
      mo: "Mo", tu: "Tu", we: "We", th: "Th", fr: "Fr", sa: "Sa", su: "Su",
      // Spanish
      lunes: "Mo", martes: "Tu", miercoles: "We", jueves: "Th",
      viernes: "Fr", sabado: "Sa", domingo: "Su",
      // Italian
      lunedi: "Mo", martedi: "Tu", mercoledi: "We", giovedi: "Th",
      venerdi: "Fr", sabato: "Sa", domenica: "Su",
      // French
      lundi: "Mo", mardi: "Tu", mercredi: "We", jeudi: "Th",
      vendredi: "Fr", samedi: "Sa", dimanche: "Su",
      // German
      montag: "Mo", dienstag: "Tu", mittwoch: "We", donnerstag: "Th",
      freitag: "Fr", samstag: "Sa", sonntag: "Su",
      // English
      monday: "Mo", tuesday: "Tu", wednesday: "We", thursday: "Th",
      friday: "Fr", saturday: "Sa", sunday: "Su",
      // Portuguese (segunda/terça/etc + the "feira" suffix is optional)
      segunda: "Mo", terca: "Tu", quarta: "We", quinta: "Th", sexta: "Fr",
    };
    const closedRe = /^(cerrado|closed|chiuso|ferme|fermee|geschlossen|fechado|riposo)\b/i;
    const stripAccents = (x) => x.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "");

    // Split a "12:30-16:0019:00-24:00" run into ["12:30-16:00", "19:00-24:00"].
    // GMaps glues multi-shift days; we re-split on the second HH:MM start.
    function splitShifts(rangeText) {
      const cleaned = rangeText.replace(/[–—−]/g, "-");
      // Match "HH:MM-HH:MM" runs greedily — one or many, possibly back-to-back.
      const matches = cleaned.match(/\d{1,2}:\d{2}\s*-\s*\d{1,2}:\d{2}/g);
      if (matches && matches.length) return matches.map((r) => r.replace(/\s+/g, "").replace("-", "–"));
      return [cleaned.trim().replace(/-/g, "–")];
    }

    const map = Object.fromEntries(order.map((d) => [d, []]));
    const tokens = s.split(/[;\n]/).map((t) => t.trim()).filter(Boolean);
    let parsed = false;
    for (const tok of tokens) {
      // OSM-strict day RANGE: "Mo-Su 19:00-22:30" / "Mo-Fr 11:00-15:00".
      // Apply the same shifts to every day in the inclusive code range.
      const range = tok.match(/^(Mo|Tu|We|Th|Fr|Sa|Su)\s*-\s*(Mo|Tu|We|Th|Fr|Sa|Su)\s+(.+)$/);
      if (range) {
        const a = order.indexOf(range[1]);
        const b = order.indexOf(range[2]);
        if (a !== -1 && b !== -1) {
          const ranges = splitShifts(range[3]);
          if (ranges.length) {
            const lo = Math.min(a, b), hi = Math.max(a, b);
            for (let k = lo; k <= hi; k++) map[order[k]].push(...ranges);
            parsed = true;
            continue;
          }
        }
      }
      // Single-day prefix — "domingo: 19:30-23:30", "Mo 13:00-17:00",
      // "lunedì: 12:00-15:00, 19:00-23:00", etc.
      const m = tok.match(/^([A-Za-zÀ-ÿ]+)(?:\s+|\s*:\s*)(.+)$/);
      if (!m) continue;
      const dayKey = stripAccents(m[1]);
      const code = dayMap[dayKey];
      if (!code) continue;
      const rest = m[2].trim();
      if (closedRe.test(rest)) {
        // Empty array means "Closed" — handled in the render path.
        parsed = true;
        continue;
      }
      const ranges = splitShifts(rest);
      if (ranges.length) {
        map[code].push(...ranges);
        parsed = true;
      }
    }
    if (!parsed) return null;

    // Collapse consecutive days with identical ranges.
    const rows = [];
    let i = 0;
    while (i < order.length) {
      const startCode = order[i];
      const sig = map[startCode].join("|");
      let j = i;
      while (j + 1 < order.length && map[order[j + 1]].join("|") === sig) j++;
      const startLabel = dayLabels[order[i]];
      const endLabel = dayLabels[order[j]];
      rows.push({
        label: i === j ? startLabel : `${startLabel}–${endLabel}`,
        ranges: map[startCode],
      });
      i = j + 1;
    }
    return rows;
  }

  const hours = parseOpeningHours(place.openingHours);

  // Stars-only rating display. Backend now stores opmRating in /5
  // directly (matching the externals + the per-category review scale),
  // so we render the 5-star row with halves straight from `value`.
  function renderStars(value, sizeClass) {
    if (value == null) return "";
    const value5 = Number(value);
    const cls = sizeClass || "stars--md";
    let html = `<span class="stars ${cls}" role="img" aria-label="${value5.toFixed(1)} out of 5 stars">`;
    for (let i = 1; i <= 5; i++) {
      let kind;
      if (value5 >= i) kind = "full";
      else if (value5 >= i - 0.5) kind = "half";
      else kind = "empty";
      html += `<span class="star star--${kind}" aria-hidden="true"></span>`;
    }
    html += `</span>`;
    return html;
  }

  // Relative-time formatter for review timestamps. Server-side gives us
  // a plausible default; the client JS overrides on render with
  // Intl.RelativeTimeFormat using the user's locale.
  function relTime(date) {
    const d = new Date(date);
    const diffMs = Date.now() - d.getTime();
    const sec = Math.round(diffMs / 1000);
    if (sec < 60) return "just now";
    const min = Math.round(sec / 60);
    if (min < 60) return `${min}m ago`;
    const hr = Math.round(min / 60);
    if (hr < 24) return `${hr}h ago`;
    const day = Math.round(hr / 24);
    if (day < 30) return `${day}d ago`;
    const mo = Math.round(day / 30);
    if (mo < 12) return `${mo}mo ago`;
    const yr = Math.round(mo / 12);
    return `${yr}y ago`;
  }

  // External aggregator reviews — secondary section, below opmRating.
  const reviews = [];
  if (place.tripadvisorRating != null) {
    reviews.push({
      platform: "TripAdvisor",
      rating: Number(place.tripadvisorRating),
      max: 5,
      count: place.tripadvisorReviewCount,
      url: place.tripadvisorUrl,
      ranking: place.tripadvisorRanking,
    });
  }
  if (place.googleRating != null) {
    reviews.push({
      platform: "Google",
      rating: Number(place.googleRating),
      max: 5,
      count: place.googleReviewCount,
      url: place.googleUrl,
    });
  }
  if (place.yelpRating != null) {
    reviews.push({
      platform: "Yelp",
      rating: Number(place.yelpRating),
      max: 5,
      count: place.yelpReviewCount,
      url: place.yelpUrl,
    });
  }

  // Show highest-rated platform first; tiebreak on review count.
  reviews.sort((a, b) => {
    const aNorm = a.rating / (a.max || 5);
    const bNorm = b.rating / (b.max || 5);
    if (bNorm !== aNorm) return bNorm - aNorm;
    return (b.count || 0) - (a.count || 0);
  });
%>
<%- include("layout", { title: place.name, user, leaflet: false, bodyClass: "place-page", body: String.raw`
  ${place.heroImageUrl ? `
    <div class="place-hero">
      <img src="${escapeAttr(largeVariant(place.heroImageUrl))}" data-fallback="${escapeAttr(place.heroImageUrl)}" alt="${escapeAttr(place.name)}" loading="eager" onerror="if(this.src!==this.dataset.fallback){this.src=this.dataset.fallback}else{this.remove()}" />
      <button type="button" class="place-fav place-fav--floating${place.viewerFavorited ? " is-active" : ""}" data-place-fav data-place-id="${place.id}" aria-pressed="${place.viewerFavorited ? "true" : "false"}" aria-label="${place.viewerFavorited ? "Remove from favourites" : "Add to favourites"}">
        <span class="material-symbols-rounded" aria-hidden="true">favorite</span>
      </button>
    </div>
  ` : ""}

  <article class="place-shell">
    ${place.isJustCreatedForViewer ? `
      <aside class="place-welcome" role="status">
        <div class="place-welcome__icon"><span class="material-symbols-rounded" aria-hidden="true">celebration</span></div>
        <div class="place-welcome__body">
          <strong>Thanks for adding ${escapeHtml(place.name)}!</strong>
          <p>We're enriching the rest (address, hours, photos, description) in the background. While you wait — drop the first review so other pizza nerds can see what you thought.</p>
        </div>
        <button type="button" class="btn primary place-welcome__cta" data-open-review data-place-id="${place.id}">Rate this place</button>
      </aside>
    ` : ""}
    <div class="place-header">
      ${place.opmRating != null ? `
        <div class="place-rating-badge place-rating-badge--inline place-rating-badge--pinned" title="OpenPizzaMap score" data-place-rating="${escapeAttr(String(Number(place.opmRating)))}">
          <strong>${escapeHtml(Number(place.opmRating).toFixed(1))}</strong>
        </div>
      ` : ""}
      <div class="place-header__main">
        <div class="place-title-row">
          <h1 class="place-title">${escapeHtml(place.name)}</h1>
        </div>
        <p class="place-address">${escapeHtml(place.addressLine || "")}${place.addressLine ? " · " : ""}${escapeHtml(place.city || "")}${place.country ? `, ${escapeHtml(place.country)}` : ""}</p>

        <div class="place-meta">
          ${place.priceLevel ? `<span class="place-price"><span class="place-price__on">${"€".repeat(place.priceLevel)}</span><span class="place-price__off">${"€".repeat(Math.max(0, 4 - place.priceLevel))}</span></span>` : ""}
          ${place.styles && place.styles.length ? place.styles.map(ps => `<span class="place-style-chip">${escapeHtml(ps.style.shortLabel || ps.style.name)}</span>`).join("") : ""}
          ${(() => {
            const pizzaBoxSvg = `<svg class="place-service__svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="6" y="3" width="15" height="3.4" rx="0.5"/><rect x="3" y="9" width="17" height="3.4" rx="0.5"/><rect x="5" y="15" width="16" height="3.4" rx="0.5"/></svg>`;
            const ms = (n) => `<span class="material-symbols-rounded" aria-hidden="true">${n}</span>`;
            const services = [];
            if (place.dineIn)         services.push({ label: "Dine-in",         icon: ms("restaurant") });
            if (place.takeaway)       services.push({ label: "Takeaway",        icon: pizzaBoxSvg });
            if (place.delivery)       services.push({ label: "Delivery",        icon: ms("delivery_dining") });
            if (place.reservations)   services.push({ label: "Reservations",    icon: ms("event_seat") });
            if (place.outdoorSeating) services.push({ label: "Outdoor seating", icon: ms("deck") });
            return services.map(s => `<span class="place-service">${s.icon}<span>${escapeHtml(s.label)}</span></span>`).join("");
          })()}
        </div>
      </div>
    </div>
    <script>
      (function () {
        const userIn = ${user ? "true" : "false"};
        const favBtns = document.querySelectorAll("[data-place-fav]");
        favBtns.forEach(btn => {
          btn.addEventListener("click", async (ev) => {
            ev.preventDefault();
            ev.stopPropagation();
            if (!userIn) { window.location.href = "/auth"; return; }
            const id = btn.dataset.placeId;
            const wasOn = btn.classList.contains("is-active");
            btn.classList.toggle("is-active", !wasOn);
            btn.setAttribute("aria-pressed", String(!wasOn));
            try {
              const r = await fetch("/api/places/" + id + "/favorite", { method: "POST" });
              if (!r.ok) throw new Error();
              const d = await r.json();
              btn.classList.toggle("is-active", !!d.favorited);
              btn.setAttribute("aria-pressed", String(!!d.favorited));
            } catch {
              btn.classList.toggle("is-active", wasOn);
              btn.setAttribute("aria-pressed", String(wasOn));
            }
          });
        });
      })();
    </script>

    <aside class="place-claim place-rate">
      <div class="place-claim__icon">
        <span class="material-symbols-rounded" aria-hidden="true">rate_review</span>
      </div>
      <div class="place-claim__body">
        <h3>${place.viewerReview ? "Update your review" : "Been here?"}</h3>
        <p>${place.viewerReview ? "Tweak your rating if you've been back lately." : "Add this spot to your pizza passport by dropping a quick rating."}</p>
      </div>
      <button type="button" class="btn primary" data-open-review data-place-id="${place.id}" aria-haspopup="dialog">${place.viewerReview ? "Edit review" : "Rate this place"}</button>
    </aside>

    ${hours ? `
      <section class="card place-hours">
        <h2 class="place-section-title">Opening hours</h2>
        <ul class="place-hours__list">
          ${hours.map((h) => `
            <li class="place-hours__row">
              <span class="place-hours__day">${escapeHtml(h.label)}</span>
              <span class="place-hours__ranges">${h.ranges.length ? h.ranges.map(escapeHtml).join(", ") : "<em>Closed</em>"}</span>
            </li>
          `).join("")}
        </ul>
      </section>
    ` : ""}

    ${place.descriptionHtml ? `
      <section class="card place-description">
        ${place.descriptionHtml}
      </section>
    ` : ""}

    ${(place.websiteUrl || place.instagramUrl || place.googleMapsUrl || place.phone) ? `
      <section class="place-actions">
        ${place.websiteUrl ? `<a class="place-action" href="${escapeAttr(place.websiteUrl)}" target="_blank" rel="noopener"><span class="material-symbols-rounded" aria-hidden="true">public</span><span>Website</span></a>` : ""}
        ${place.instagramUrl ? `<a class="place-action place-action--instagram" href="${escapeAttr(place.instagramUrl)}" target="_blank" rel="noopener"><svg class="place-action__brand" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38a3.7 3.7 0 0 1-1.38.9c-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38a3.7 3.7 0 0 1 1.38-.9c.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.34 4.14.63 3.36.93 2.7 1.34 2.04 2 1.39 2.66.97 3.32.67 4.1.38 4.86.17 5.74.11 7.01.05 8.29.04 8.7.04 11.96s.01 3.67.07 4.95c.06 1.27.27 2.15.56 2.91.3.78.71 1.44 1.37 2.1.66.66 1.32 1.07 2.1 1.37.76.29 1.64.5 2.91.56 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.27-.06 2.15-.27 2.91-.56.78-.3 1.44-.71 2.1-1.37.66-.66 1.07-1.32 1.37-2.1.29-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.27-2.15-.56-2.91-.3-.78-.71-1.44-1.37-2.1A5.85 5.85 0 0 0 19.86.63C19.1.34 18.22.13 16.95.07 15.67.01 15.26 0 12 0Zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32M12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8m6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88"/></svg><span>Instagram</span></a>` : ""}
        ${place.googleMapsUrl ? `<a class="place-action" href="${escapeAttr(place.googleMapsUrl)}" target="_blank" rel="noopener"><span class="material-symbols-rounded" aria-hidden="true">directions</span><span>Directions</span></a>` : ""}
        ${place.phone ? `<a class="place-action" href="tel:${escapeAttr(place.phone.replace(/\s+/g, ""))}"><span class="material-symbols-rounded" aria-hidden="true">call</span><span>${escapeHtml(place.phone)}</span></a>` : ""}
      </section>
    ` : ""}

    ${reviews.length ? `
      <section class="card place-reviews">
        <h2 class="place-section-title">Other ratings</h2>
        <div class="place-reviews__grid">
          ${reviews.map((r) => `
            ${r.url ? `<a class="place-review" href="${escapeAttr(r.url)}" target="_blank" rel="noopener">` : `<div class="place-review">`}
              <div class="place-review__platform">${escapeHtml(r.platform)}</div>
              <div class="place-review__score">
                <span class="material-symbols-rounded" aria-hidden="true">star</span>
                <strong>${escapeHtml(r.rating.toFixed(1))}</strong>
              </div>
              <div class="place-review__count">${r.count != null ? `${r.count.toLocaleString()} reviews` : ""}</div>
              ${r.ranking ? `<div class="place-review__ranking">${escapeHtml(r.ranking)}</div>` : ""}
            ${r.url ? `</a>` : `</div>`}
          `).join("")}
        </div>
      </section>
    ` : ""}

    ${place.reviewsTotal > 0 ? `
      <section class="card place-community-reviews">
        <div class="place-community-reviews__header">
          <div class="place-community-reviews__heading">
            <h2 class="place-section-title">Community reviews</h2>
            <span class="place-community-reviews__count">${place.reviewsTotal}</span>
          </div>
          <div class="place-community-reviews__nav-wrap">
            <button type="button" class="place-community-reviews__nav" data-rail-prev aria-label="Previous reviews" hidden>
              <span class="material-symbols-rounded" aria-hidden="true">chevron_left</span>
            </button>
            <button type="button" class="place-community-reviews__nav" data-rail-next aria-label="More reviews" hidden>
              <span class="material-symbols-rounded" aria-hidden="true">chevron_right</span>
            </button>
          </div>
        </div>

        ${place.reviewAverages ? `
          <ul class="place-rating-summary" aria-label="Average ratings by category">
            ${[
              { label: "Pizza",   value: place.reviewAverages.pizza },
              { label: "Setting", value: place.reviewAverages.local },
              { label: "Service", value: place.reviewAverages.servicio },
              { label: "Value",   value: place.reviewAverages.precio },
            ].map((row) => `
              <li class="place-rating-summary__row">
                <span class="place-rating-summary__label">${row.label}</span>
                <span class="place-rating-summary__stars">${row.value != null ? renderStars(row.value, "stars--sm") : ""}</span>
                <span class="place-rating-summary__num">${row.value != null ? row.value.toFixed(1) : "—"}</span>
              </li>
            `).join("")}
          </ul>
        ` : ""}

        <div class="place-community-reviews__rail" data-reviews-rail>
        <ul class="place-community-reviews__list" data-reviews-list data-place-id="${place.id}" data-loaded-count="${place.reviewsFirstPage.length}" data-total="${place.reviewsTotal}" data-page-size="${place.reviewPageSize}">
          ${place.reviewsFirstPage.map((r) => {
            const avg = ((Number(r.pizza) + Number(r.local) + Number(r.servicio) + Number(r.precio)) / 4);
            const initial = (r.userName || "?").trim().charAt(0).toUpperCase();
            const avatarHtml = r.userAvatar
              ? `<span class="opm-review__avatar opm-review__avatar--img"><img src="${escapeAttr(r.userAvatar)}" alt="" referrerpolicy="no-referrer" onerror="this.parentNode.outerHTML='<span class=&quot;opm-review__avatar&quot; aria-hidden=&quot;true&quot;>${escapeHtml(initial)}</span>'" /></span>`
              : `<span class="opm-review__avatar" aria-hidden="true">${escapeHtml(initial)}</span>`;
            return `
            <li class="opm-review">
              <div class="opm-review__head">
                <div class="opm-review__who">
                  ${avatarHtml}
                  <div class="opm-review__id">
                    <span class="opm-review__user">${escapeHtml(r.userName)}</span>
                    <time class="opm-review__time" datetime="${escapeAttr(new Date(r.createdAt).toISOString())}" data-rel-time>${escapeHtml(relTime(r.createdAt))}</time>
                  </div>
                </div>
                <div class="opm-review__badge" title="Average across Pizza, Setting, Service, Value (out of 5)" aria-label="${avg.toFixed(1)} out of 5">
                  <strong>${avg.toFixed(1)}</strong>
                </div>
              </div>
              ${r.comment ? `<blockquote class="opm-review__comment">${escapeHtml(r.comment)}</blockquote>` : ""}
            </li>
          `;
          }).join("")}
        </ul>
        </div>
        ${place.reviewsTotal > place.reviewsFirstPage.length ? `
          <button type="button" class="btn opm-reviews-more" data-load-more-reviews>Show more</button>
        ` : ""}
      </section>
    ` : ""}

    ${place.faqs && place.faqs.length ? `
      <section class="place-faqs">
        <h2 class="place-section-title">FAQ</h2>
        ${place.faqs.map(f => `
          <details class="card place-faq">
            <summary>${escapeHtml(f.question)}</summary>
            <div class="place-faq__body">${f.answerHtml}</div>
          </details>
        `).join("")}
      </section>
    ` : ""}

    <aside class="place-claim">
      <div class="place-claim__icon">
        <span class="material-symbols-rounded" aria-hidden="true">verified</span>
      </div>
      <div class="place-claim__body">
        <h3>Are you the owner?</h3>
        <p>Claim this listing to manage photos, opening hours and respond to visitors.</p>
      </div>
      <a class="btn primary" href="/place/${place.id}/suggest-edit">Claim this place</a>
    </aside>

    <footer class="place-footer">
      <a class="btn" href="/map">← Back to map</a>
      ${user ? `<a class="btn" href="/place/${place.id}/suggest-edit">Suggest an edit</a>` : ""}
    </footer>
  </article>

  <!-- Review modal: bottom-sheet on mobile, centred dialog on desktop. -->
  <div class="review-modal" data-review-modal data-place-id="${place.id}" data-place-name="${escapeAttr(place.name)}" data-has-existing="${place.viewerReview ? "1" : "0"}" hidden>
    <div class="review-modal__backdrop" data-review-close></div>
    <div class="review-modal__sheet" role="dialog" aria-modal="true" aria-labelledby="review-modal-title">
      <header class="review-modal__head">
        <button type="button" class="review-modal__close" data-review-close aria-label="Close">
          <span class="material-symbols-rounded" aria-hidden="true">close</span>
        </button>
        <h2 class="review-modal__title" id="review-modal-title">How was ${escapeHtml(place.name)}?</h2>
      </header>
      <form class="review-modal__form" data-review-form>
        <fieldset class="review-modal__rows">
          <div class="review-row" data-review-cat="pizza">
            <span class="review-row__label">Pizza <span class="review-row__emoji" aria-hidden="true">🍕</span></span>
            <div class="star-input" data-star-input data-name="pizza"></div>
          </div>
          <div class="review-row" data-review-cat="local">
            <span class="review-row__label">Setting <span class="review-row__emoji" aria-hidden="true">🏠</span></span>
            <div class="star-input" data-star-input data-name="local"></div>
          </div>
          <div class="review-row" data-review-cat="servicio">
            <span class="review-row__label">Service <span class="review-row__emoji" aria-hidden="true">🤵</span></span>
            <div class="star-input" data-star-input data-name="servicio"></div>
          </div>
          <div class="review-row" data-review-cat="precio">
            <span class="review-row__label">Value <span class="review-row__emoji" aria-hidden="true">💶</span></span>
            <div class="star-input" data-star-input data-name="precio"></div>
          </div>
        </fieldset>
        <fieldset class="review-modal__price" data-review-price>
          <legend class="review-row__label">Price range</legend>
          <div class="price-input" role="radiogroup" aria-label="Price range">
            <button type="button" class="price-input__chip" data-price-chip="1" aria-pressed="false">€<span class="visually-hidden"> — cheap</span></button>
            <button type="button" class="price-input__chip" data-price-chip="2" aria-pressed="false">€€<span class="visually-hidden"> — mid</span></button>
            <button type="button" class="price-input__chip" data-price-chip="3" aria-pressed="false">€€€<span class="visually-hidden"> — splurge</span></button>
          </div>
          <input type="hidden" name="priceLevel" data-price-input value="${place.priceLevel || ''}" />
        </fieldset>
        <label class="review-modal__comment-wrap">
          <span class="review-modal__comment-label">Tell us about your visit</span>
          <textarea class="review-modal__comment" data-review-comment required minlength="4" maxlength="500" rows="3" placeholder="What stood out? What would you tell a friend?">${place.viewerReview && place.viewerReview.comment ? escapeHtml(place.viewerReview.comment) : ""}</textarea>
          <span class="review-modal__counter" data-review-counter>0 / 500</span>
        </label>
        <div class="review-modal__error" data-review-error hidden></div>
        <button type="submit" class="btn primary review-modal__submit" data-review-submit disabled>Submit</button>
      </form>
    </div>
  </div>
  ${place.viewerReview ? `
    <script type="application/json" id="opm-existing-review">${JSON.stringify({
      pizza: place.viewerReview.pizza,
      local: place.viewerReview.local,
      servicio: place.viewerReview.servicio,
      precio: place.viewerReview.precio,
      comment: place.viewerReview.comment || "",
    })}</script>
  ` : ""}
  <div class="opm-toast" data-opm-toast hidden></div>
  <script src="/public/js/place-review.js?v=${assetVersion || ''}" defer></script>
` }) %>
