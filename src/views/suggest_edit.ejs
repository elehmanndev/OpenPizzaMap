<%- include("layout", { title: `Suggest an edit · ${place.name}`, user, leaflet: false, bodyClass: "auth-page", body: String.raw`
  <section class="auth-wrap">
    <div class="auth-card">
      <h1 class="auth-title">Suggest an edit</h1>
      <p class="auth-subtitle">Your suggestion will be reviewed by an admin before it goes live.</p>

      <div class="card">
        <div><strong>${escapeHtml(place.name)}</strong></div>
        <div class="small">${escapeHtml(place.city)} · ${escapeHtml(place.country)}</div>
      </div>

      <form class="auth-form" id="suggest" novalidate>
        <label class="auth-field">
          <span>Description</span>
          <div id="editor" style="background: var(--c-input-bg); border: 1px solid var(--c-border); border-radius: 12px;"></div>
          <small class="auth-hint">Keep it factual. No promos or spam.</small>
        </label>
        <label class="auth-field">
          <span>Website URL</span>
          <input name="websiteUrl" type="url" placeholder="https://..." value="${escapeAttr(place.websiteUrl || "")}" />
          <small class="auth-error" aria-live="polite"></small>
        </label>
        <label class="auth-field">
          <span>Instagram URL</span>
          <input name="instagramUrl" type="url" placeholder="https://instagram.com/..." value="${escapeAttr(place.instagramUrl || "")}" />
          <small class="auth-error" aria-live="polite"></small>
        </label>
        <label class="auth-field">
          <span>Google Maps URL</span>
          <input name="googleMapsUrl" type="url" placeholder="https://maps.google.com/..." value="${escapeAttr(place.googleMapsUrl || "")}" />
          <small class="auth-error" aria-live="polite"></small>
        </label>
        <input type="hidden" name="descriptionHtml" id="descriptionHtml" />
        <button class="auth-submit auth-submit-solid" type="submit">Submit suggestion</button>
        <p class="auth-msg" id="msg"></p>
      </form>
      <p class="auth-footer"><a href="/place/${place.id}">Back to place</a></p>
    </div>
  </section>

  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
  <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
  <script>
    (function () {
      var editorEl = document.getElementById("editor");
      var desc = document.getElementById("descriptionHtml");
      var form = document.getElementById("suggest");
      var msg = document.getElementById("msg");
      if (!editorEl || !desc || !form) return;

      var quill = new Quill(editorEl, {
        theme: "snow",
        modules: { toolbar: [["bold", "italic", "underline"], [{ list: "ordered" }, { list: "bullet" }], ["link"]] },
      });
      quill.root.innerHTML = ${JSON.stringify(place.descriptionHtml || "")};

      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        msg.textContent = "";
        desc.value = quill.root.innerHTML || "";
        var fd = new FormData(form);
        var payload = Object.fromEntries(fd.entries());
        try {
          var res = await fetch("/api/submissions", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              type: "edit_place",
              targetPlaceId: ${place.id},
              payload: payload,
            }),
          });
          var data = await res.json();
          if (data && data.ok) {
            msg.textContent = "Submitted. Thanks!";
            msg.style.color = "var(--c-success)";
            form.reset();
            quill.root.innerHTML = "";
            return;
          }
          msg.textContent = (data && data.error) ? (typeof data.error === "string" ? data.error : "Submission failed") : "Submission failed";
          msg.style.color = "var(--c-warn)";
        } catch (err) {
          msg.textContent = "Submission failed";
          msg.style.color = "var(--c-warn)";
        }
      });
    })();
  </script>
` }) %>
